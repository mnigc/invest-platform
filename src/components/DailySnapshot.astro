---
import type { UsSnapshotData, CnSnapshotData } from '../lib/api'

import CnHeader from './snapshot/cn/CnHeader'
import CnHeroPanel from './snapshot/cn/CnHeroPanel'
import CnValuation from './snapshot/cn/CnValuation'
import CnOutlook from './snapshot/cn/CnOutlook'

import UsHeader from './snapshot/us/UsHeader'
import UsMacroRisk from './snapshot/us/UsMacroRisk'
import UsSummary from './snapshot/us/UsSummary'
import UsHeroPanel from './regime/UsHeroPanel'
import AnomalyAlertPanel from './regime/AnomalyAlertPanel'
import BacktestPanel from './regime/BacktestPanel'

const PORT = import.meta.env.PORT || 4321
let usData: UsSnapshotData | null = null
let cnData: CnSnapshotData | null = null

try {
  const API_BASE = import.meta.env.API_BASE || `http://127.0.0.1:${PORT}/api/v1`
  const [usRes, cnRes] = await Promise.all([
    fetch(`${API_BASE}/snapshot/us.json`, { headers: { 'Accept': 'application/json' } }),
    fetch(`${API_BASE}/snapshot/cn.json`, { headers: { 'Accept': 'application/json' } }),
  ])
  if (usRes.ok) {
    const json = await usRes.json()
    if (json.success) usData = json.data
  }
  if (cnRes.ok) {
    const json = await cnRes.json()
    if (json.success) cnData = json.data
  }
} catch (e: any) {
  console.error('[DailySnapshot] SSR fetch failed:', e.message)
}
---

<div class="snapshot-container">
  <div class="snapshot-header">
    <div class="header-content">
      <div class="header-main">
        <div class="header-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <div class="header-text">
          <h1>市场仪表盘</h1>
          <p>每日市场快照 · 专业宏观数据分析</p>
        </div>
      </div>
      <div class="header-meta">
        <div class="tabs-container">
          <button class="tab-btn" data-tab="cn" role="tab" aria-selected="true">
            <span>🇨🇳 中国市场</span>
          </button>
          <button class="tab-btn" data-tab="us" role="tab" aria-selected="false">
            <span>🇺🇸 美国市场</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="snapshot-content" id="snapshotContent">
    <div class="tab-content" data-panel="cn">
      <CnHeader data={cnData?.header} client:load />
      <CnHeroPanel indices={cnData?.indices} client:load />
      <div class="panels-grid-3col">
        <CnValuation data={cnData?.valuation} client:load />
        <CnOutlook data={cnData?.summary} client:load />
      </div>
      <div class="indicator-links-panel">
        <div class="indicator-links-title">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          中国经济指标
        </div>
        <div class="indicator-links">
          <a href="/indicators/CN/GDP" class="indicator-link"><span class="indicator-code">GDP</span><span class="indicator-name">国内生产总值</span></a>
          <a href="/indicators/CN/CPI" class="indicator-link"><span class="indicator-code">CPI</span><span class="indicator-name">居民消费价格指数</span></a>
          <a href="/indicators/CN/PPI" class="indicator-link"><span class="indicator-code">PPI</span><span class="indicator-name">工业生产者出厂价格</span></a>
          <a href="/indicators/CN/PMI" class="indicator-link"><span class="indicator-code">PMI</span><span class="indicator-name">制造业采购经理人指数</span></a>
          <a href="/indicators/CN/RETAIL" class="indicator-link"><span class="indicator-code">RETAIL</span><span class="indicator-name">社会消费品零售总额</span></a>
        </div>
      </div>
    </div>

    <div class="tab-content" data-panel="us" hidden>
      <UsHeader data={usData?.header} client:load />
      <UsHeroPanel indices={usData?.coreIndices} client:load />
      <div class="panels-grid-3col">
        <UsMacroRisk data={usData?.macroRisk} client:load />
        <AnomalyAlertPanel client:load />
      </div>
      <div class="panels-grid">
        <BacktestPanel client:load class="full-span" />
        <UsSummary data={usData?.summary} client:load class="full-span" />
      </div>
      <div class="indicator-links-panel">
        <div class="indicator-links-title">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          美国经济指标
        </div>
        <div class="indicator-links">
          <a href="/indicators/US/GDP" class="indicator-link"><span class="indicator-code">GDP</span><span class="indicator-name">国内生产总值</span></a>
          <a href="/indicators/US/CPI" class="indicator-link"><span class="indicator-code">CPI</span><span class="indicator-name">居民消费价格指数</span></a>
          <a href="/indicators/US/PPI" class="indicator-link"><span class="indicator-code">PPI</span><span class="indicator-name">生产者价格指数</span></a>
          <a href="/indicators/US/PCE" class="indicator-link"><span class="indicator-code">PCE</span><span class="indicator-name">个人消费支出物价</span></a>
          <a href="/indicators/US/PMI" class="indicator-link"><span class="indicator-code">PMI</span><span class="indicator-name">制造业采购经理人指数</span></a>
          <a href="/indicators/US/UMCSENT" class="indicator-link"><span class="indicator-code">UMCSENT</span><span class="indicator-name">消费者信心指数</span></a>
          <a href="/indicators/US/RSXFS" class="indicator-link"><span class="indicator-code">RSXFS</span><span class="indicator-name">零售销售</span></a>
          <a href="/indicators/US/FEDFUNDS" class="indicator-link"><span class="indicator-code">FEDFUNDS</span><span class="indicator-name">联邦基金利率</span></a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    const STORAGE_KEY = 'marketSnapshotTab';
    const tabs = document.querySelectorAll('.tab-btn');
    const panels: Record<string, HTMLElement | null> = {
      cn: document.querySelector('[data-panel="cn"]'),
      us: document.querySelector('[data-panel="us"]'),
    };

    function activateTab(tabId: string) {
      tabs.forEach(t => {
        const isActive = t.getAttribute('data-tab') === tabId;
        t.classList.toggle('active', isActive);
        t.setAttribute('aria-selected', String(isActive));
      });
      Object.entries(panels).forEach(([id, el]) => {
        if (el) el.hidden = id !== tabId;
      });
      try { localStorage.setItem(STORAGE_KEY, tabId); } catch {}
    }

    const saved = (() => {
      try { return localStorage.getItem(STORAGE_KEY); } catch { return null; }
    })();
    activateTab(saved === 'us' ? 'us' : 'cn');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => activateTab(tab.getAttribute('data-tab')!));
    });
  })();
</script>

<style>
  .snapshot-container { width: 100%; }
  .snapshot-header { margin-bottom: 16px; }
  .header-content { display: flex; align-items: center; justify-content: space-between; gap: 20px; }
  .header-main { display: flex; align-items: center; gap: 12px; }
  .header-icon {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: var(--radius-md);
    background: var(--gradient-brand); color: #fff; flex-shrink: 0;
  }
  .header-text h1 {
    font-size: 20px; font-weight: 700; font-family: var(--font-display);
    color: var(--text-primary); margin: 0; letter-spacing: 0.02em;
  }
  .header-text p { font-size: 13px; color: var(--text-muted); margin: 2px 0 0 0; font-weight: 500; }
  .header-meta { display: flex; align-items: center; gap: 16px; }
  .live-indicator {
    display: flex; align-items: center; gap: 6px; padding: 6px 12px;
    border-radius: 20px; background: var(--accent-cyan-dim);
    border: 1px solid rgba(6, 182, 212, 0.2);
  }
  .live-indicator .live-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent-cyan); animation: neonPulse 2s ease-in-out infinite;
  }
  .live-indicator span { font-size: 12px; font-weight: 600; color: var(--accent-cyan); font-family: var(--font-display); letter-spacing: 0.06em; }
  .tabs-container {
    display: flex; gap: 8px; background: var(--bg-card);
    border-radius: var(--radius-lg); padding: 4px; border: 1px solid var(--border-light);
  }
  .tab-btn {
    display: flex; align-items: center; gap: 8px; padding: 8px 20px;
    border-radius: var(--radius-md); border: none; background: transparent;
    color: var(--text-muted); font-size: 14px; font-weight: 600;
    font-family: var(--font-display); letter-spacing: 0.04em;
    cursor: pointer; transition: all var(--transition-base);
  }
  .tab-btn:hover { color: var(--text-secondary); background: var(--bg-card-hover); }
  .tab-btn.active { color: var(--text-primary); background: var(--accent-blue-dim); box-shadow: var(--shadow-sm); }
  .panels-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-top: 12px;
  }
  .full-span { grid-column: span 2; }
  .tab-content[hidden] { display: none; }
  @media (max-width: 1100px) {
    .panels-grid { grid-template-columns: 1fr; }
    .full-span { grid-column: span 1; }
  }
  @media (max-width: 1400px) {
    .header-content { flex-wrap: wrap; }
    .tabs-container { order: -1; margin-left: auto; }
  }

  .panels-grid-3col {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 12px;
  }
  @media (max-width: 1200px) {
    .panels-grid-3col { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 900px) {
    .panels-grid-3col { grid-template-columns: 1fr; }
  }

  .indicator-links-panel {
    margin-top: 16px;
    padding: 16px 18px;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
  }
  .indicator-links-title {
    display: flex; align-items: center; gap: 8px;
    font-size: 12px; font-weight: 700; color: var(--text-secondary);
    text-transform: uppercase; letter-spacing: 0.06em;
    margin-bottom: 12px;
  }
  .indicator-links-title svg { color: var(--accent-cyan); }
  .indicator-links {
    display: flex; flex-wrap: wrap; gap: 10px;
  }
  .indicator-link {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 8px 14px; border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-light);
    color: var(--text-secondary); text-decoration: none;
    transition: all var(--transition-fast);
  }
  .indicator-link:hover {
    background: var(--accent-blue-dim);
    border-color: var(--accent-blue);
    color: var(--text-primary);
  }
  .indicator-code {
    font-family: var(--font-mono); font-size: 11px; font-weight: 700;
    color: var(--accent-cyan); min-width: 44px;
  }
  .indicator-name { font-size: 12px; font-weight: 500; }
</style>
