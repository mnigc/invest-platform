---
const usIndicators = [
  { label: 'GDP', href: '/indicators/US/GDP' },
  { label: 'CPI', href: '/indicators/US/CPI' },
  { label: 'PPI', href: '/indicators/US/PPI' },
  { label: '个人消费支出', href: '/indicators/US/PCE' },
  { label: '消费者信心指数', href: '/indicators/US/UMCSENT' },
  { label: '零售销售', href: '/indicators/US/RSXFS' },
];

const cnIndicators = [
  { label: 'GDP', href: '/indicators/CN/GDP' },
  { label: 'CPI', href: '/indicators/CN/CPI' },
  { label: 'PPI', href: '/indicators/CN/PPI' },
  { label: '社会消费品零售总额', href: '/indicators/CN/RETAIL' },
];

const navSections = [
  {
    items: [
      { label: '市场仪表盘', href: '/' },
    ],
  },
  {
    title: '美国经济指标',
    items: usIndicators,
  },
  {
    title: '中国经济指标',
    items: cnIndicators,
  },
  {
    items: [
      { label: '研究库', href: '/library' },
    ],
  },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<aside class="sidebar">
  <div class="sidebar-brand">
    <div class="brand-icon">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
      </svg>
    </div>
    <div class="brand-text">
      <div class="brand-title">CN-US MACRO</div>
      <div class="brand-sub">中美宏观数据研究平台</div>
    </div>
  </div>

  <nav class="nav">
    {navSections.map(section => (
      <div class="nav-section">
        {section.title && <div class="category-label">{section.title}</div>}
        {section.items.map(item => (
          <a
            href={item.href}
            class={`nav-link ${isActive(item.href) ? 'active' : ''} ${section.title ? 'sub' : ''}`}
          >
            <span class="nav-indicator"></span>
            <span class="label">{item.label}</span>
          </a>
        ))}
      </div>
    ))}
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-footer-text">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <span>FRED · Yahoo · akshare</span>
    </div>
  </div>
</aside>

<style>
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: var(--sidebar-width);
    height: 100vh;
    background: var(--bg-secondary);
    border-right: 1px solid var(--border-light);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    z-index: 100;
  }

  .sidebar-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 18px 16px 16px;
    background: var(--bg-card);
  }

  .brand-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: var(--radius-md);
    background: var(--gradient-brand);
    color: #fff;
    flex-shrink: 0;
  }

  .brand-title {
    font-size: 15px;
    font-weight: 700;
    font-family: var(--font-display);
    letter-spacing: 0.06em;
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .brand-sub {
    font-size: 10px;
    color: var(--text-muted);
    margin-top: 1px;
    letter-spacing: 0.04em;
  }

  .nav {
    padding: 8px;
    flex: 1;
  }

  .nav-section {
    margin-bottom: 4px;
  }

  .nav-link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 12px;
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-size: 13px;
    transition: all var(--transition-base);
    margin-bottom: 1px;
    overflow: hidden;
  }

  .nav-link::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--accent-blue-dim) 0%, transparent 100%);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .nav-link:hover {
    color: var(--text-primary);
    background: var(--bg-card-hover);
  }

  .nav-link:hover::before {
    opacity: 1;
  }

  .nav-link.active {
    color: var(--accent-blue);
    background: var(--accent-blue-dim);
  }

  .nav-link.active::before {
    opacity: 1;
  }

  .nav-indicator {
    width: 3px;
    height: 14px;
    border-radius: 2px;
    background: transparent;
    transition: all var(--transition-base);
    flex-shrink: 0;
  }

  .nav-link.active .nav-indicator {
    background: var(--accent-blue);
  }

  .nav-link.sub {
    padding-left: 28px;
    font-size: 12px;
  }

  .label {
    position: relative;
    z-index: 1;
  }

  .category-label {
    padding: 10px 12px 4px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    font-family: var(--font-display);
  }

  .sidebar-footer {
    padding: 12px 16px;
  }

  .sidebar-footer-text {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    color: var(--text-muted);
  }
</style>