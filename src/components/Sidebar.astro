---
const usIndicators = [
  { label: 'GDP', href: '/indicators/US/GDP' },
  { label: 'CPI', href: '/indicators/US/CPI' },
  { label: 'PPI', href: '/indicators/US/PPI' },
  { label: '个人消费支出', href: '/indicators/US/PCE' },
  { label: '消费者信心指数', href: '/indicators/US/UMCSENT' },
  { label: '零售销售', href: '/indicators/US/RSXFS' },
  { label: 'PMI', href: '/indicators/US/pmi' },
  { label: '国债收益率', href: '/indicators/US/bonds' },
];

const cnIndicators = [
  { label: 'GDP', href: '/indicators/CN/GDP' },
  { label: 'CPI', href: '/indicators/CN/CPI' },
  { label: 'PPI', href: '/indicators/CN/PPI' },
  { label: '制造业PMI', href: '/indicators/CN/PMI' },
  { label: '社会消费品零售总额', href: '/indicators/CN/RETAIL' },
  { label: '国债收益率', href: '/indicators/CN/bonds' },
];

const navSections = [
  {
    items: [
      { label: '市场总览', href: '/' },
    ],
  },
  {
    title: '美国经济指标',
    items: usIndicators,
  },
  {
    title: '中国经济指标',
    items: cnIndicators,
  },
  {
    title: '跨市场分析',
    items: [
      { label: '中美 10Y 利差', href: '/indicators/cn-us-spread' },
      { label: '全球流动性', href: '/indicators/global-liquidity' },
      { label: '经济冷暖指标', href: '/indicators/heatmap' },
      { label: 'Z-Score 矩阵', href: '/indicators/zscore-matrix' },
      { label: '汇率总览', href: '/indicators/forex' },
    ],
  },
  {
    title: '大宗商品',
    items: [
      { label: '黄金', href: '/gold' },
      { label: '商品期限结构', href: '/indicators/commodity-curve' },
      { label: 'VIX 波动率', href: '/indicators/vix' },
    ],
  },
  {
    items: [
      { label: '研究库', href: '/library' },
    ],
  },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<aside class="sidebar" id="sidebar">
  <div class="sidebar-brand">
    <div class="brand-icon">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
      </svg>
    </div>
    <div class="brand-text">
      <div class="brand-title">CN-US MACRO</div>
      <div class="brand-sub">中美宏观数据研究平台</div>
    </div>
    <button class="sidebar-close" id="sidebarCloseBtn" aria-label="关闭导航">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <nav class="nav">
    {navSections.map(section => (
      <div class="nav-section">
        {section.title && <div class="category-label">{section.title}</div>}
        {section.items.map(item => (
          <a
            href={item.href}
            class={`nav-link ${isActive(item.href) ? 'active' : ''} ${section.title ? 'sub' : ''}`}
            data-sidebar-link
          >
            <span class="nav-indicator"></span>
            <span class="label">{item.label}</span>
          </a>
        ))}
      </div>
    ))}
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-footer-text">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <span>FRED · Yahoo · akshare</span>
    </div>
    <button id="themeToggleBtn" class="theme-toggle" title="切换主题" aria-label="切换主题" aria-pressed="false">
      <span id="themeToggleIcon">🖥️</span>
    </button>
  </div>
</aside>

<div class="sidebar-overlay" id="sidebarOverlay" aria-hidden="true"></div>

<script>
  (function() {
    var btn = document.getElementById('themeToggleBtn');
    var icon = document.getElementById('themeToggleIcon');
    var sidebar = document.getElementById('sidebar');
    var overlay = document.getElementById('sidebarOverlay');
    var closeBtn = document.getElementById('sidebarCloseBtn');
    if (!btn || !icon) return;

    var THEME_COLORS = { dark: '#000000', light: '#f5f7fa' };
    var PREF_ICONS = { dark: '🌙', light: '☀️', auto: '🖥️' };
    var PREF_LABELS = { dark: '深色模式', light: '浅色模式', auto: '跟随系统' };

    function getPref() {
      var pref = document.documentElement.dataset.themePref;
      if (pref !== 'dark' && pref !== 'light' && pref !== 'auto') {
        pref = 'auto';
      }
      return pref;
    }

    function resolveTheme(pref) {
      if (pref === 'dark' || pref === 'light') return pref;
      return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    }

    function updateUI() {
      var pref = getPref();
      var theme = document.documentElement.dataset.theme;
      icon.textContent = PREF_ICONS[pref];
      var themeLabel = theme === 'dark' ? '深色' : '浅色';
      btn.title = PREF_LABELS[pref] + '（当前: ' + themeLabel + '）';
      btn.setAttribute('aria-pressed', theme === 'light' ? 'true' : 'false');
      var meta = document.querySelector('meta[name="theme-color"]');
      if (meta) meta.setAttribute('content', THEME_COLORS[theme]);
    }

    function applyAndSync(pref) {
      var doc = document.documentElement;
      var theme = resolveTheme(pref);
      doc.dataset.theme = theme;
      doc.dataset.themePref = pref;
      var bg = theme === 'light' ? '#f5f7fa' : '#000000';
      var text = theme === 'light' ? '#1a1a2e' : '#FFFFFF';
      doc.style.backgroundColor = bg;
      doc.style.color = text;
      doc.style.setProperty('--bg-primary', bg);
      doc.style.setProperty('--text-primary', text);
      doc.style.colorScheme = theme;
      doc.classList.add('theme-transitioning');
      setTimeout(function() { doc.classList.remove('theme-transitioning'); }, 400);
      try { localStorage.setItem('theme', pref); } catch(e) {}
      updateUI();
    }

    function openSidebar() {
      if (!sidebar) return;
      sidebar.classList.add('sidebar-open');
      if (overlay) {
        overlay.classList.add('sidebar-overlay-open');
        overlay.setAttribute('aria-hidden', 'false');
      }
      document.body.style.overflow = 'hidden';
    }
    function closeSidebar() {
      if (!sidebar) return;
      sidebar.classList.remove('sidebar-open');
      if (overlay) {
        overlay.classList.remove('sidebar-overlay-open');
        overlay.setAttribute('aria-hidden', 'true');
      }
      document.body.style.overflow = '';
    }

    // 汉堡按钮由 Layout.astro 提供，事件委托到 document
    document.addEventListener('click', function(e) {
      var target = e.target;
      if (!target) return;
      var hamburger = target.closest('[data-sidebar-toggle]');
      if (hamburger) {
        if (sidebar && sidebar.classList.contains('sidebar-open')) {
          closeSidebar();
        } else {
          openSidebar();
        }
        return;
      }
      if (closeBtn && target.closest('#sidebarCloseBtn')) {
        closeSidebar();
        return;
      }
      if (target.closest('#sidebarOverlay')) {
        closeSidebar();
        return;
      }
      var link = target.closest('[data-sidebar-link]');
      if (link) {
        closeSidebar();
      }
    });

    // Esc 关闭
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeSidebar();
    });

    // 切到桌面尺寸时自动关闭抽屉
    var mqWidth = window.matchMedia('(min-width: 768px)');
    mqWidth.addEventListener('change', function(e) {
      if (e.matches) closeSidebar();
    });

    updateUI();

    btn.addEventListener('click', function() {
      var pref = getPref();
      var next = pref === 'dark' ? 'light' : pref === 'light' ? 'auto' : 'dark';
      applyAndSync(next);
    });

    var mq = window.matchMedia('(prefers-color-scheme: dark)');
    mq.addEventListener('change', function() {
      if (getPref() === 'auto') {
        applyAndSync('auto');
      }
    });
  })();
</script>

<style>
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: var(--sidebar-width);
    height: 100vh;
    background: var(--bg-primary);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    z-index: 200;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .sidebar-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 18px 16px 16px;
    background: var(--bg-primary);
  }

  .brand-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: var(--radius-md);
    background: var(--gradient-brand);
    color: #fff;
    flex-shrink: 0;
  }

  .brand-title {
    font-size: 15px;
    font-weight: 700;
    font-family: var(--font-display);
    letter-spacing: 0.06em;
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .brand-sub {
    font-size: 10px;
    color: var(--text-muted);
    margin-top: 1px;
    letter-spacing: 0.04em;
  }

  .sidebar-close {
    display: none;
    margin-left: auto;
    background: transparent;
    border: 1px solid var(--border-light);
    border-radius: 8px;
    width: 32px;
    height: 32px;
    color: var(--text-muted);
    cursor: pointer;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .nav {
    padding: 8px;
    flex: 1 1 auto;
    overflow-y: auto;
    min-height: 0;
  }

  .nav-section {
    margin-bottom: 4px;
  }

  .nav-link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 12px;
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-size: 13px;
    transition: all var(--transition-base);
    margin-bottom: 1px;
    overflow: hidden;
  }

  .nav-link::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--accent-blue-dim) 0%, transparent 100%);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .nav-link:hover {
    color: var(--text-primary);
    background: var(--bg-card-hover);
  }

  .nav-link:hover::before {
    opacity: 1;
  }

  .nav-link.active {
    color: var(--accent-blue);
    background: var(--accent-blue-dim);
  }

  .nav-link.active::before {
    opacity: 1;
  }

  .nav-indicator {
    width: 3px;
    height: 14px;
    border-radius: 2px;
    background: transparent;
    transition: all var(--transition-base);
    flex-shrink: 0;
  }

  .nav-link.active .nav-indicator {
    background: var(--accent-blue);
  }

  .nav-link.sub {
    padding-left: 28px;
    font-size: 12px;
  }

  .label {
    position: relative;
    z-index: 1;
  }

  .category-label {
    padding: 10px 12px 4px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    font-family: var(--font-display);
  }

  .sidebar-footer {
    padding: 12px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }

  .sidebar-footer-text {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    color: var(--text-muted);
  }

  .theme-toggle {
    background: transparent;
    border: 1px solid var(--border-light);
    border-radius: 8px;
    cursor: pointer;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    transition: all var(--transition-fast);
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    background: var(--bg-card-hover);
    border-color: var(--accent-blue);
  }

  /* 遮罩层 — 仅在移动端抽屉状态显示 */
  .sidebar-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease;
    z-index: 150;
    pointer-events: none;
  }

  /* 移动端响应式 */
  @media (max-width: 767px) {
    .sidebar {
      transform: translateX(-100%);
      width: 86vw;
      max-width: 320px;
      box-shadow: var(--shadow-lg);
    }

    .sidebar.sidebar-open {
      transform: translateX(0);
    }

    .sidebar-overlay.sidebar-overlay-open {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    .sidebar-close {
      display: flex;
    }
  }
</style>


