---
interface Props {
  data?: Array<{ code: string; name: string; change: number; price?: number }> | null
}
const { data } = Astro.props as Props

const sectors = (data ?? [])
  .filter((s: any) => s.change != null)
  .sort((a: any, b: any) => Number(b.change) - Number(a.change))

const top5 = sectors.slice(0, 5)
const bottom3 = sectors.slice(-3).reverse()

function fmt(v: any, suffix = '') {
  if (v == null) return '-';
  return (v >= 0 ? '+' : '') + Number(v).toFixed(2) + suffix;
}
---

<div class="snapshot-panel">
  <div class="snapshot-panel-header">
    <div class="snapshot-panel-title">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      <span>板块题材轮动</span>
    </div>
    <span class="snapshot-panel-badge">申万一级</span>
  </div>

  {sectors.length === 0 ? (
    <div class="empty-state">暂无板块数据</div>
  ) : (
    <>
      <div class="sector-section">
        <div class="sector-header">
          <span class="section-title">强势行业 TOP 5</span>
        </div>
        {top5.map((s: any) => (
          <div class="sector-row">
            <span class="sector-name">{s.name}</span>
            <div class="sector-bar-wrap">
              <div class="sector-bar" style={`width: ${Math.min(Math.abs(Number(s.change)) * 40, 100)}%; background: var(--green);`}></div>
            </div>
            <span class="sector-val" style="color: var(--green);">{fmt(s.change, '%')}</span>
          </div>
        ))}
      </div>

      {bottom3.length > 0 && (
        <div class="sector-divider"></div>
      )}

      {bottom3.length > 0 && (
        <div class="sector-section">
          <div class="sector-header">
            <span class="section-title">弱势行业 BOTTOM 3</span>
          </div>
          {bottom3.map((s: any) => (
            <div class="sector-row">
              <span class="sector-name">{s.name}</span>
              <div class="sector-bar-wrap">
                <div class="sector-bar" style={`width: ${Math.min(Math.abs(Number(s.change)) * 40, 100)}%; background: var(--red);`}></div>
              </div>
              <span class="sector-val" style="color: var(--red);">{fmt(s.change, '%')}</span>
            </div>
          ))}
        </div>
      )}
    </>
  )}
</div>

<style>
  .snapshot-panel {
    background: var(--bg-card); border-radius: var(--radius-lg);
    border: 1px solid var(--border-light); padding: 16px;
  }
  .snapshot-panel-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 14px;
  }
  .snapshot-panel-title {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; font-weight: 600; color: var(--text-primary);
    font-family: var(--font-display);
  }
  .snapshot-panel-title svg { color: var(--accent-blue); }
  .snapshot-panel-badge {
    font-size: 10px; padding: 2px 8px; border-radius: 10px;
    background: var(--accent-teal-dim); color: var(--accent-teal);
    font-weight: 600; font-family: var(--font-display); letter-spacing: 0.04em;
  }
  .empty-state {
    padding: 24px 0; text-align: center; color: var(--text-muted);
    font-size: 13px;
  }
  .sector-section { margin-bottom: 8px; }
  .sector-header { display: flex; justify-content: space-between; margin-bottom: 8px; }
  .section-title { font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; }
  .sector-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .sector-name { width: 70px; font-size: 12px; color: var(--text-primary); font-weight: 500; flex-shrink: 0; }
  .sector-bar-wrap { flex: 1; height: 6px; background: var(--bg-card-hover); border-radius: 3px; overflow: hidden; }
  .sector-bar { height: 100%; border-radius: 3px; transition: width 0.3s ease; }
  .sector-val { width: 60px; text-align: right; font-size: 12px; font-weight: 600; font-variant-numeric: tabular-nums; }
  .sector-divider { height: 1px; background: var(--border-light); margin: 10px 0; }
</style>
