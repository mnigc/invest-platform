---
interface Props {
  data?: null
}
---

<div class="snapshot-panel">
  <div class="snapshot-panel-header">
    <div class="snapshot-panel-title">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      <span>政策 & 风险</span>
    </div>
  </div>
  <div class="empty-state">
    <span>数据待补充（需接入政策事件及解禁预警数据）</span>
  </div>
</div>

<style>
  .snapshot-panel {
    background: var(--bg-card); border-radius: var(--radius-lg);
    border: 1px solid var(--border-light); padding: 16px;
  }
  .snapshot-panel-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 14px;
  }
  .snapshot-panel-title {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; font-weight: 600; color: var(--text-primary);
    font-family: var(--font-display);
  }
  .snapshot-panel-title svg { color: var(--red); }
  .empty-state {
    padding: 32px 0; text-align: center; color: var(--text-muted);
    font-size: 13px;
  }
</style>
