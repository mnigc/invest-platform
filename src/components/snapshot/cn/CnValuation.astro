---
interface Props {
  data?: {
    overallPE?: number
    overallSignal?: string
    industries: Array<{ name: string; pe: number; pb: number; stockCount: number }>
  } | null
}
const { data } = Astro.props as Props

const industries = (data?.industries ?? [])
  .filter((v: any) => v.pe != null && v.pe > 0)

const topVal = industries.slice(0, 5)
const bottomVal = [...industries].reverse().slice(0, 5)

function fmt(v: any, suffix = '') {
  if (v == null) return '-';
  return Number(v).toFixed?.(1) + suffix;
}
---

<div class="snapshot-panel">
  <div class="snapshot-panel-header">
    <div class="snapshot-panel-title">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <span>行业估值分位</span>
    </div>
    <span class="snapshot-panel-badge">{data?.overallSignal ?? '--'}</span>
  </div>

  {industries.length === 0 ? (
    <div class="empty-state">暂无估值数据（个股数据已精简）</div>
  ) : (
    <>
      {data?.overallPE != null && (
        <div class="market-pe">
          <span class="pe-label">全市场估值</span>
          <span class="pe-value">{fmt(data.overallPE)}x</span>
          <span class="pe-signal" data-signal={data.overallSignal}>{data.overallSignal}</span>
        </div>
      )}

      <div class="val-section">
        <div class="section-title-wrap">
          <span class="section-title">高估行业 TOP 5</span>
        </div>
        {topVal.map((v: any) => (
          <div class="val-row">
            <span class="val-name">{v.name}</span>
            <span class="val-pe">PE {fmt(v.pe)}</span>
            <span class="val-pb">PB {fmt(v.pb)}</span>
            <span class="val-count">{v.stockCount} 只</span>
          </div>
        ))}
      </div>

      <div class="val-divider"></div>

      <div class="val-section">
        <div class="section-title-wrap">
          <span class="section-title">低估行业 BOTTOM 5</span>
        </div>
        {bottomVal.map((v: any) => (
          <div class="val-row">
            <span class="val-name">{v.name}</span>
            <span class="val-pe">PE {fmt(v.pe)}</span>
            <span class="val-pb">PB {fmt(v.pb)}</span>
            <span class="val-count">{v.stockCount} 只</span>
          </div>
        ))}
      </div>
    </>
  )}
</div>

<style>
  .snapshot-panel {
    background: var(--bg-card); border-radius: var(--radius-lg);
    border: 1px solid var(--border-light); padding: 16px;
  }
  .snapshot-panel-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 14px;
  }
  .snapshot-panel-title {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; font-weight: 600; color: var(--text-primary);
    font-family: var(--font-display);
  }
  .snapshot-panel-title svg { color: var(--accent-purple); }
  .snapshot-panel-badge {
    font-size: 10px; padding: 2px 8px; border-radius: 10px;
    font-weight: 600; font-family: var(--font-display); letter-spacing: 0.04em;
    background: var(--accent-orange-dim); color: var(--accent-orange);
  }
  .empty-state {
    padding: 24px 0; text-align: center; color: var(--text-muted);
    font-size: 13px;
  }
  .market-pe {
    display: flex; align-items: center; gap: 8px; margin-bottom: 14px;
    padding: 10px 12px; background: var(--bg-card-hover);
    border-radius: var(--radius-md);
  }
  .pe-label { font-size: 12px; color: var(--text-muted); }
  .pe-value { font-size: 20px; font-weight: 700; color: var(--text-primary); font-variant-numeric: tabular-nums; }
  .pe-signal {
    margin-left: auto; font-size: 11px; font-weight: 600; padding: 2px 8px;
    border-radius: 8px;
  }
  .pe-signal[data-signal="偏低"] { background: var(--green-bg); color: var(--green); }
  .pe-signal[data-signal="中性"] { background: var(--accent-orange-dim); color: var(--accent-orange); }
  .pe-signal[data-signal="偏高"] { background: var(--red-bg); color: var(--red); }
  .val-section { margin-bottom: 4px; }
  .section-title-wrap { margin-bottom: 8px; }
  .section-title {
    font-size: 11px; font-weight: 600; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .val-row {
    display: flex; align-items: center; gap: 8px; padding: 5px 0;
    border-bottom: 1px solid var(--border-light);
  }
  .val-row:last-child { border-bottom: none; }
  .val-name { width: 70px; font-size: 12px; color: var(--text-primary); font-weight: 500; flex-shrink: 0; }
  .val-pe { width: 60px; font-size: 12px; color: var(--text-secondary); font-variant-numeric: tabular-nums; }
  .val-pb { width: 60px; font-size: 12px; color: var(--text-muted); font-variant-numeric: tabular-nums; }
  .val-count { margin-left: auto; font-size: 10px; color: var(--text-muted); }
  .val-divider { height: 1px; background: var(--border-light); margin: 10px 0; }
</style>
