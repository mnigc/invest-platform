---
interface Props {
  data?: {
    volume: Array<{ symbol: string; name: string; ratio: number; change: number }>
    options: Array<{ symbol: string; name: string; premium: number; direction: string }>
    momentum: Array<{ symbol: string; name: string; change: number; reason: string }>
    reversal: Array<{ symbol: string; name: string; change: number; reason: string }>
  } | null
}
const { data } = Astro.props as Props
const volItems = data?.volume ?? []
const optItems = data?.options ?? []
const momItems = data?.momentum ?? []
const revItems = data?.reversal ?? []
const hasAny = volItems.length > 0 || optItems.length > 0 || momItems.length > 0 || revItems.length > 0

function fmt(v: any, suffix = '') {
  if (v == null) return '-';
  return (v >= 0 ? '+' : '') + Number(v).toFixed(2) + suffix;
}
---

<div class="snapshot-panel">
  <div class="snapshot-panel-header">
    <div class="snapshot-panel-title">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      <span>个股异动监测</span>
    </div>
  </div>

  {!hasAny ? (
    <div class="empty-state">暂无个股异动数据</div>
  ) : (
    <>
      {volItems.length > 0 && (
        <div class="section-block">
          <div class="section-title">放量异动</div>
          {volItems.map((v: any) => (
            <div class="anomaly-row">
              <div class="anomaly-left">
                <span class="anomaly-sym">{v.symbol}</span>
                <span class="anomaly-name">{v.name}</span>
              </div>
              <div class="anomaly-right">
                <span class="anomaly-tag">{Number(v.ratio).toFixed(1)}x</span>
                <span class="anomaly-chg" style={`color: ${Number(v.change) >= 0 ? 'var(--green)' : 'var(--red)'}`}>
                  {fmt(v.change, '%')}
                </span>
              </div>
            </div>
          ))}
        </div>
      )}

      {optItems.length > 0 && (
        <div class="section-block">
          <div class="section-title">期权异动</div>
          {optItems.map((o: any) => (
            <div class="anomaly-row">
              <div class="anomaly-left">
                <span class="anomaly-sym">{o.symbol}</span>
                <span class="anomaly-name">{o.name}</span>
              </div>
              <div class="anomaly-right">
                <span class="anomaly-tag">{o.direction === 'call' ? '看涨' : '看跌'}</span>
                <span class="anomaly-chg" style="color: var(--accent-orange);">${Number(o.premium).toFixed(1)}M</span>
              </div>
            </div>
          ))}
        </div>
      )}

      {(momItems.length > 0 || revItems.length > 0) && (
        <div class="cand-section">
          {momItems.length > 0 && (
            <div class="cand-block">
              <div class="section-title">动量</div>
              {momItems.map((m: any) => (
                <div class="cand-row">
                  <span class="cand-sym">{m.symbol}</span>
                  <span class="cand-name">{m.reason}</span>
                  <span class="cand-chg" style="color: var(--green);">{fmt(m.change, '%')}</span>
                </div>
              ))}
            </div>
          )}
          {revItems.length > 0 && (
            <div class="cand-block">
              <div class="section-title">反转</div>
              {revItems.map((r: any) => (
                <div class="cand-row">
                  <span class="cand-sym">{r.symbol}</span>
                  <span class="cand-name">{r.reason}</span>
                  <span class="cand-chg" style="color: var(--red);">{fmt(r.change, '%')}</span>
                </div>
              ))}
            </div>
          )}
        </div>
      )}
    </>
  )}
</div>

<style>
  .snapshot-panel {
    background: var(--bg-card); border-radius: var(--radius-lg);
    border: 1px solid var(--border-light); padding: 16px;
  }
  .snapshot-panel-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 14px;
  }
  .snapshot-panel-title {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; font-weight: 600; color: var(--text-primary);
    font-family: var(--font-display);
  }
  .snapshot-panel-title svg { color: var(--red); }
  .empty-state {
    padding: 24px 0; text-align: center; color: var(--text-muted);
    font-size: 13px;
  }
  .section-block { margin-bottom: 14px; }
  .section-title {
    font-size: 11px; font-weight: 600; color: var(--text-muted);
    margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.08em;
  }
  .anomaly-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 6px 0; border-bottom: 1px solid var(--border-light);
  }
  .anomaly-row:last-child { border-bottom: none; }
  .anomaly-left { display: flex; align-items: center; gap: 8px; }
  .anomaly-sym { font-size: 12px; font-weight: 700; color: var(--text-primary); font-family: var(--font-mono); }
  .anomaly-name { font-size: 11px; color: var(--text-muted); }
  .anomaly-right { display: flex; align-items: center; gap: 8px; }
  .anomaly-tag {
    font-size: 10px; padding: 1px 6px; border-radius: 6px;
    background: var(--accent-orange-dim); color: var(--accent-orange); font-weight: 600;
  }
  .anomaly-chg { font-size: 12px; font-weight: 600; font-variant-numeric: tabular-nums; }
  .cand-section { display: flex; gap: 12px; }
  .cand-block { flex: 1; }
  .cand-row {
    display: flex; align-items: center; gap: 6px; padding: 4px 0;
  }
  .cand-sym { font-size: 12px; font-weight: 700; color: var(--text-primary); font-family: var(--font-mono); }
  .cand-name { font-size: 11px; color: var(--text-muted); flex: 1; }
  .cand-chg { font-size: 12px; font-weight: 600; font-variant-numeric: tabular-nums; }
</style>
