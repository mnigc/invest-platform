---
interface Props {
  data?: {
    breadth?: { advance?: number; decline?: number; newHigh?: number; newLow?: number }
    maDist?: { above20?: number; above50?: number; above200?: number }
    mag7?: Array<{ symbol: string; name: string; change: number }>
    sox?: { price: number; change: number }
  } | null
}
const { data } = Astro.props as Props

const breadth = data?.breadth
const maDist = data?.maDist
const mag7 = data?.mag7 ?? []
const sox = data?.sox
const hasAnyData = breadth || maDist || mag7.length > 0 || sox

function fmt(v: any, suffix = '') {
  if (v == null) return '-'
  return (v >= 0 ? '+' : '') + Number(v).toFixed(2) + suffix
}

function pctVal(v: any) {
  if (v == null) return '-'
  return Number(v).toFixed(0) + '%'
}
---

<div class="snapshot-panel">
  <div class="snapshot-panel-header">
    <div class="snapshot-panel-title">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg>
      <span>市场内部结构</span>
    </div>
  </div>

  {!hasAnyData ? (
    <div class="empty-state">暂无市场内部数据</div>
  ) : (
    <>
      {breadth && (
        <div class="grid-4">
          <div class="stat-cell">
            <span class="stat-label">上涨</span>
            <span class="stat-val" style="color: var(--green);">{breadth.advance ?? '-'}</span>
          </div>
          <div class="stat-cell">
            <span class="stat-label">下跌</span>
            <span class="stat-val" style="color: var(--red);">{breadth.decline ?? '-'}</span>
          </div>
          <div class="stat-cell">
            <span class="stat-label">新高</span>
            <span class="stat-val" style="color: var(--green);">{breadth.newHigh ?? '-'}</span>
          </div>
          <div class="stat-cell">
            <span class="stat-label">新低</span>
            <span class="stat-val" style="color: var(--red);">{breadth.newLow ?? '-'}</span>
          </div>
        </div>
      )}

      {maDist && (
        <div class="ma-section">
          <div class="section-label">均线分布</div>
          <div class="ma-row">
            <span class="ma-name">> MA20</span>
            <div class="ma-bar-bg">
              <div class="ma-bar" style={`width: ${maDist.above20 ?? 0}%`}></div>
            </div>
            <span class="ma-pct">{pctVal(maDist.above20)}</span>
          </div>
          <div class="ma-row">
            <span class="ma-name">> MA50</span>
            <div class="ma-bar-bg">
              <div class="ma-bar" style={`width: ${maDist.above50 ?? 0}%`}></div>
            </div>
            <span class="ma-pct">{pctVal(maDist.above50)}</span>
          </div>
          <div class="ma-row">
            <span class="ma-name">> MA200</span>
            <div class="ma-bar-bg">
              <div class="ma-bar" style={`width: ${maDist.above200 ?? 0}%`}></div>
            </div>
            <span class="ma-pct">{pctVal(maDist.above200)}</span>
          </div>
        </div>
      )}

      {mag7.length > 0 && (
        <div class="mag7-section">
          <div class="section-label">Mag7 七巨头</div>
          <div class="mag7-grid">
            {mag7.map((s: any) => {
              const ch = Number(s.change)
              return (
                <div class="mag7-chip">
                  <span class="chip-sym">{s.symbol}</span>
                  <span class="chip-name">{s.name}</span>
                  <span class="chip-chg" style={`color: ${ch >= 0 ? 'var(--green)' : 'var(--red)'}`}>
                    {fmt(ch, '%')}
                  </span>
                </div>
              )
            })}
          </div>
        </div>
      )}

      {sox && (
        <div class="sox-row">
          <span class="sox-label">费城半导体 SOX</span>
          <span class="sox-price">{Number(sox.price).toFixed(2)}</span>
          <span class="sox-chg" style={`color: ${Number(sox.change) >= 0 ? 'var(--green)' : 'var(--red)'}`}>
            {fmt(sox.change, '%')}
          </span>
        </div>
      )}
    </>
  )}
</div>

<style>
  .snapshot-panel {
    background: var(--bg-card); border-radius: var(--radius-lg);
    border: 1px solid var(--border-light); padding: 16px;
  }
  .snapshot-panel-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 14px;
  }
  .snapshot-panel-title {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; font-weight: 600; color: var(--text-primary);
    font-family: var(--font-display);
  }
  .snapshot-panel-title svg { color: var(--accent-cyan); }
  .empty-state {
    padding: 24px 0; text-align: center; color: var(--text-muted);
    font-size: 13px;
  }
  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 14px; }
  .stat-cell {
    text-align: center; padding: 8px 4px;
    background: var(--bg-card-hover); border-radius: var(--radius-md);
  }
  .stat-label { display: block; font-size: 10px; color: var(--text-muted); margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.06em; }
  .stat-val { font-size: 16px; font-weight: 700; font-variant-numeric: tabular-nums; }
  .ma-section { margin-bottom: 14px; }
  .section-label {
    font-size: 11px; font-weight: 600; color: var(--text-muted);
    margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.08em;
  }
  .ma-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .ma-name { width: 55px; font-size: 11px; color: var(--text-secondary); }
  .ma-bar-bg { flex: 1; height: 6px; background: var(--bg-card-hover); border-radius: 3px; overflow: hidden; }
  .ma-bar { height: 100%; background: var(--accent-blue); border-radius: 3px; transition: width 0.3s ease; }
  .ma-pct { width: 35px; text-align: right; font-size: 11px; font-weight: 600; color: var(--text-primary); font-variant-numeric: tabular-nums; }
  .mag7-section { margin-bottom: 10px; }
  .mag7-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; }
  .mag7-chip {
    padding: 6px 8px; background: var(--bg-card-hover); border-radius: var(--radius-md);
    display: flex; flex-direction: column; align-items: center; gap: 2px;
  }
  .chip-sym { font-size: 10px; font-weight: 700; color: var(--text-secondary); font-family: var(--font-mono); }
  .chip-name { font-size: 9px; color: var(--text-muted); }
  .chip-chg { font-size: 12px; font-weight: 700; font-variant-numeric: tabular-nums; }
  .sox-row {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 10px; background: var(--bg-card-hover); border-radius: var(--radius-md);
  }
  .sox-label { font-size: 11px; color: var(--text-secondary); }
  .sox-price { margin-left: auto; font-size: 14px; font-weight: 700; color: var(--text-primary); font-variant-numeric: tabular-nums; }
  .sox-chg { font-size: 12px; font-weight: 600; font-variant-numeric: tabular-nums; }
</style>
