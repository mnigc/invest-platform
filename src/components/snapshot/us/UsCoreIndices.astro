---
interface Props {
  data?: Array<{ symbol: string; name: string; price: number; change: number }> | null
}

const { data } = Astro.props as Props

const fallbackIndices = [
  { name: 'S&P 500', code: 'SPX', value: 5487.03, change: 0.25, up: true },
  { name: 'NASDAQ 100', code: 'NDX', value: 19685.42, change: 0.68, up: true },
  { name: 'Dow Jones', code: 'DJI', value: 38920.35, change: -0.12, up: false },
  { name: 'Russell 2000', code: 'RUT', value: 2042.18, change: -0.45, up: false },
]

const indices = data?.length
  ? data.map(d => ({
      name: d.name,
      code: d.symbol.replace('^', ''),
      value: d.price,
      change: d.change,
      up: d.change >= 0,
    }))
  : fallbackIndices

function fmt(v: any, suffix = '') {
  if (v == null) return '-';
  return (v >= 0 ? '+' : '') + Number(v).toFixed(2) + suffix;
}
---

<div class="snapshot-panel">
  <div class="snapshot-panel-header">
    <div class="snapshot-panel-title">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      <span>核心指数</span>
    </div>
    <span class="snapshot-panel-badge">1D</span>
  </div>
  
  <div class="core-indices-section">
    <div class="indices-header">
      <span class="section-title">主要指数</span>
      <span class="indices-desc">SPX/NDX/DJI/RUT</span>
    </div>
    <div class="indices-grid">
      {indices.map(idx => (
        <div class="index-card">
          <div class="index-main">
            <div class="index-info">
              <span class="index-name">{idx.name}</span>
              <span class="index-code">{idx.code}</span>
            </div>
            <div class="index-value-row">
              <span class="index-value">{Number(idx.value).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</span>
              <div class={`index-change ${idx.up ? 'up' : 'down'}`}>
                <svg class="change-arrow" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  {idx.up
                    ? <polyline points="18 15 12 9 6 15"/>
                    : <polyline points="6 9 12 15 18 9"/>
                  }
                </svg>
                <span class="change-text">{fmt(idx.change, '%')}</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .snapshot-panel { background: var(--bg-card); border: 1px solid var(--border-light); border-radius: var(--radius-xl); padding: 16px; transition: all var(--transition-base); box-shadow: var(--shadow-sm); }
  .snapshot-panel:hover { border-color: var(--accent-blue); box-shadow: var(--shadow-blue); }
  .snapshot-panel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; padding-bottom: 8px; border-bottom: 1px solid var(--border-light); }
  .snapshot-panel-title { display: flex; align-items: center; gap: 8px; font-size: 15px; font-weight: 600; font-family: var(--font-display); letter-spacing: 0.04em; color: var(--text-primary); }
  .snapshot-panel-title svg { color: var(--accent-blue); flex-shrink: 0; }
  .snapshot-panel-badge { font-size: 12px; padding: 4px 12px; border-radius: 8px; background: var(--accent-cyan-dim); color: var(--accent-cyan); font-family: var(--font-mono); letter-spacing: 0.04em; font-weight: 600; }
  .core-indices-section { margin-bottom: 12px; }
  .indices-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 8px; }
  .section-title { font-size: 13px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; }
  .indices-desc { font-size: 12px; color: var(--text-muted); font-family: var(--font-mono); }
  .indices-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
  .index-card { padding: 10px; border-radius: var(--radius-md); background: var(--bg-card); border: 1px solid var(--border-light); transition: all var(--transition-base); }
  .index-card:hover { background: var(--bg-card-hover); border-color: var(--accent-blue); transform: translateY(-2px); box-shadow: var(--shadow-blue); }
  .index-main { display: flex; flex-direction: column; gap: 6px; }
  .index-info { display: flex; flex-direction: column; gap: 3px; }
  .index-name { font-size: 14px; font-weight: 500; color: var(--text-primary); line-height: 1.3; }
  .index-code { font-size: 11px; color: var(--text-muted); font-family: var(--font-mono); letter-spacing: 0.04em; }
  .index-value-row { display: flex; align-items: center; justify-content: space-between; margin-top: 6px; }
  .index-value { font-size: 22px; font-weight: 700; font-family: var(--font-mono); color: var(--text-primary); letter-spacing: -0.02em; }
  .index-change { display: inline-flex; align-items: center; gap: 4px; font-size: 12px; font-weight: 600; font-family: var(--font-mono); padding: 3px 8px; border-radius: 4px; }
  .index-change.up { color: var(--red); background: var(--red-bg); border: 1px solid var(--red-bg); }
  .index-change.down { color: var(--green); background: var(--green-bg); border: 1px solid var(--green-bg); }
  .change-arrow { flex-shrink: 0; }
  .change-text { font-weight: 600; }
</style>
