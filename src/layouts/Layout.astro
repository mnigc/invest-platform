---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import ClientRoot from '../components/ClientRoot';

interface Props {
  title?: string;
}

const { title = 'CN-US MACRO - 中美宏观数据研究平台' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <script is:inline>
      // 防闪烁：在首次渲染前从 localStorage + 系统偏好确定主题
      // 必须用 is:inline，确保在 CSS 加载前同步执行
      // localStorage 存用户偏好：'dark' / 'light' / 'auto'，未设置时默认 'auto'
      (function() {
        var pref = null;
        try { pref = localStorage.getItem('theme'); } catch(e) {}
        if (pref !== 'dark' && pref !== 'light' && pref !== 'auto') {
          pref = 'auto';
        }
        var theme;
        if (pref === 'dark' || pref === 'light') {
          theme = pref;
        } else {
          // auto：跟随系统
          theme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        }
        var doc = document.documentElement;
        doc.dataset.theme = theme;
        doc.dataset.themePref = pref; // 供按钮读取用户偏好
        // CSS 加载前就直接设置 html 背景色和文字色，消除任何闪烁
        var isLight = theme === 'light';
        var bg = isLight ? '#f5f7fa' : '#000000';
        var text = isLight ? '#1a1a2e' : '#FFFFFF';
        doc.style.backgroundColor = bg;
        doc.style.color = text;
        doc.style.setProperty('--bg-primary', bg);
        doc.style.setProperty('--text-primary', text);
        doc.style.colorScheme = theme;
        var meta = document.querySelector('meta[name="theme-color"]');
        if (meta) meta.setAttribute('content', bg);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content="投资数据与内容平台 - 宏观经济数据、投资大师文献、A股数据" />
    <meta name="theme-color" content="#f5f7fa" />
  </head>
  <body>
    <div id="globalLoader" class="global-loader" aria-hidden="true">
      <div class="global-loader-bar"></div>
    </div>
    <Sidebar />
    <header class="header">
      <button class="hamburger" data-sidebar-toggle aria-label="打开导航" aria-pressed="false">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
      <div class="header-right">
        <div class="status-badge">
          <span class="status-dot"></span>
          <span>LIVE</span>
        </div>
        <span class="header-time" id="headerTime">--:--:--</span>
      </div>
    </header>
    <main class="main">
      <ClientRoot client:load>
        <slot />
      </ClientRoot>
    </main>
  </body>
</html>

<script>
  function updateTime() {
    const el = document.getElementById('headerTime');
    if (el) {
      const now = new Date();
      const s = now.toLocaleString('zh-CN', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
      el.textContent = s;
    }
  }
  updateTime();
  setInterval(updateTime, 1000);

  // 全局页面导航 loading 进度条
  const loader = document.getElementById('globalLoader');
  let loaderTimer = null;
  let fallbackTimer = null;

  function showLoader() {
    if (!loader || loader.classList.contains('active')) return;
    loader.classList.add('active');
    let progress = 0;
    if (loaderTimer) window.clearInterval(loaderTimer);
    loaderTimer = window.setInterval(() => {
      progress = Math.min(progress + Math.random() * 3, 90);
      const bar = loader.querySelector('.global-loader-bar');
      if (bar) bar.style.width = `${progress}%`;
    }, 200);
  }

  function hideLoader() {
    if (loaderTimer) {
      window.clearInterval(loaderTimer);
      loaderTimer = null;
    }
    const bar = loader?.querySelector('.global-loader-bar');
    if (bar) bar.style.width = '100%';
    setTimeout(() => {
      loader?.classList.remove('active');
      if (bar) bar.style.width = '0%';
    }, 300);
  }

  // 点击内部链接时显示 loading
  document.addEventListener('click', (e) => {
    const target = e.target;
    const link = target.closest('a');
    if (!link) return;
    const href = link.getAttribute('href') || '';
    if (
      !href ||
      href.startsWith('#') ||
      href.startsWith('http') ||
      href.startsWith('mailto:') ||
      href.startsWith('tel:') ||
      link.hasAttribute('download') ||
      link.target === '_blank' ||
      e.metaKey || e.ctrlKey || e.shiftKey
    ) return;

    let url;
    try {
      url = new URL(href, window.location.origin);
    } catch (e2) { return; }
    if (url.origin !== window.location.origin) return;
    if (url.pathname === window.location.pathname && url.search === window.location.search) return;

    showLoader();
    if (fallbackTimer) window.clearTimeout(fallbackTimer);
    fallbackTimer = window.setTimeout(hideLoader, 4000);
  });

  window.addEventListener('pageshow', hideLoader);
  window.addEventListener('pagehide', hideLoader);
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: var(--sidebar-width);
    right: 0;
    height: var(--header-height);
    background: color-mix(in srgb, var(--bg-primary) 35%, transparent);
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 32px;
    z-index: 50;
    gap: 12px;
  }

  .hamburger {
    display: none;
    background: transparent;
    border: 1px solid var(--border-light);
    border-radius: 8px;
    width: 36px;
    height: 36px;
    align-items: center;
    justify-content: center;
    color: var(--text-primary);
    cursor: pointer;
    flex-shrink: 0;
  }

  .header-left {
    display: flex;
    align-items: center;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
  }

  .breadcrumb a {
    color: var(--text-muted);
    transition: color var(--transition-fast);
  }

  .breadcrumb a:hover {
    color: var(--accent-cyan);
  }

  .breadcrumb a:last-of-type {
    color: var(--text-secondary);
    pointer-events: none;
  }

  .sep {
    color: var(--border-color);
    font-size: 10px;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .status-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 10px;
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--accent-cyan);
    background: var(--accent-cyan-dim);
    border: 1px solid var(--accent-cyan-dim);
  }

  .status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent-cyan);
    animation: neonPulse 2s ease-in-out infinite;
  }

  .header-time {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.08em;
  }

  .main {
    margin-left: var(--sidebar-width);
    margin-top: var(--header-height);
    min-height: calc(100vh - var(--header-height));
    padding: 28px 32px;
    max-width: 1400px;
    margin-left: calc(var(--sidebar-width) + max(0px, (100vw - var(--sidebar-width) - 1400px) / 2));
  }

  /* 移动端响应式 */
  @media (max-width: 1100px) {
    .main {
      padding: 20px 18px;
    }
  }

  @media (max-width: 767px) {
    .header {
      left: 0;
      padding: 0 16px;
    }

    .hamburger {
      display: flex;
    }

    .main {
      margin-left: 0;
      padding: 16px 14px;
      max-width: none;
      margin-left: 0;
    }
  }

  @media (max-width: 480px) {
    .header {
      padding: 0 12px;
    }

    .header-right {
      gap: 8px;
    }

    .status-badge {
      padding: 4px 8px;
      font-size: 9px;
    }

    .header-time {
      font-size: 11px;
    }

    .main {
      padding: 14px 12px;
    }
  }

  .global-loader {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 9999;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .global-loader.active {
    opacity: 1;
  }

  .global-loader-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--accent-blue) 0%, var(--accent-cyan) 100%);
    box-shadow: 0 0 10px var(--accent-cyan);
    transition: width 0.2s ease;
  }
</style>