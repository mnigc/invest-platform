---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import ClientRoot from '../components/ClientRoot';

interface Props {
  title?: string;
}

const { title = 'CN-US MACRO - 中美宏观数据研究平台' } = Astro.props;
const pathParts = Astro.url.pathname.split('/').filter(Boolean);
const labelMap: Record<string, string> = {
  indicators: '经济指标',
  library: '研究库',
  reports: '每日报告',
  stock: '个股策略',
  gold: '黄金数据',
  US: '美国',
  CN: '中国',
};
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="投资数据与内容平台 - 宏观经济数据、投资大师文献、A股数据" />
  </head>
  <body>
    <div id="globalLoader" class="global-loader" aria-hidden="true">
      <div class="global-loader-bar"></div>
    </div>
    <Sidebar />
    <header class="header">
      <div class="header-left">
        <div class="breadcrumb">
          <a href="/">首页</a>
          {pathParts.map((part, i) => {
            const href = '/' + pathParts.slice(0, i + 1).join('/');
            const label = labelMap[part] || part;
            return <><span class="sep">/</span><a href={href}>{label}</a></>
          })}
        </div>
      </div>
      <div class="header-right">
        <div class="status-badge">
          <span class="status-dot"></span>
          <span>LIVE</span>
        </div>
        <span class="header-time" id="headerTime">--:--:--</span>
      </div>
    </header>
    <main class="main">
      <ClientRoot client:load>
        <slot />
      </ClientRoot>
    </main>
  </body>
</html>

<script>
  function updateTime() {
    const el = document.getElementById('headerTime');
    if (el) {
      const now = new Date();
      const s = now.toLocaleString('zh-CN', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
      el.textContent = s;
    }
  }
  updateTime();
  setInterval(updateTime, 1000);

  // 全局页面导航 loading 进度条
  const loader = document.getElementById('globalLoader');
  let loaderTimer = null;
  let fallbackTimer = null;

  function showLoader() {
    if (!loader || loader.classList.contains('active')) return;
    loader.classList.add('active');
    let progress = 0;
    if (loaderTimer) window.clearInterval(loaderTimer);
    loaderTimer = window.setInterval(() => {
      progress = Math.min(progress + Math.random() * 3, 90);
      const bar = loader.querySelector('.global-loader-bar');
      if (bar) bar.style.width = `${progress}%`;
    }, 200);
  }

  function hideLoader() {
    if (loaderTimer) {
      window.clearInterval(loaderTimer);
      loaderTimer = null;
    }
    const bar = loader?.querySelector('.global-loader-bar');
    if (bar) bar.style.width = '100%';
    setTimeout(() => {
      loader?.classList.remove('active');
      if (bar) bar.style.width = '0%';
    }, 300);
  }

  // 点击内部链接时显示 loading
  document.addEventListener('click', (e) => {
    const target = e.target;
    const link = target.closest('a');
    if (!link) return;
    const href = link.getAttribute('href') || '';
    if (
      !href ||
      href.startsWith('#') ||
      href.startsWith('http') ||
      href.startsWith('mailto:') ||
      href.startsWith('tel:') ||
      link.hasAttribute('download') ||
      link.target === '_blank' ||
      e.metaKey || e.ctrlKey || e.shiftKey
    ) return;

    let url;
    try {
      url = new URL(href, window.location.origin);
    } catch (e2) { return; }
    if (url.origin !== window.location.origin) return;
    if (url.pathname === window.location.pathname && url.search === window.location.search) return;

    showLoader();
    if (fallbackTimer) window.clearTimeout(fallbackTimer);
    fallbackTimer = window.setTimeout(hideLoader, 4000);
  });

  window.addEventListener('pageshow', hideLoader);
  window.addEventListener('pagehide', hideLoader);
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: var(--sidebar-width);
    right: 0;
    height: var(--header-height);
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 32px;
    z-index: 50;
  }

  .header-left {
    display: flex;
    align-items: center;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
  }

  .breadcrumb a {
    color: var(--text-muted);
    transition: color var(--transition-fast);
  }

  .breadcrumb a:hover {
    color: var(--accent-cyan);
  }

  .breadcrumb a:last-of-type {
    color: var(--text-secondary);
    pointer-events: none;
  }

  .sep {
    color: var(--border-color);
    font-size: 10px;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .status-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 10px;
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--accent-cyan);
    background: var(--accent-cyan-dim);
    border: 1px solid rgba(6, 182, 212, 0.2);
  }

  .status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent-cyan);
    animation: neonPulse 2s ease-in-out infinite;
  }

  .header-time {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.08em;
  }

  .main {
    margin-left: var(--sidebar-width);
    margin-top: var(--header-height);
    min-height: calc(100vh - var(--header-height));
    padding: 28px 32px;
    animation: fadeIn 0.3s ease;
  }

  .global-loader {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 9999;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .global-loader.active {
    opacity: 1;
  }

  .global-loader-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--accent-blue) 0%, var(--accent-cyan) 100%);
    box-shadow: 0 0 10px rgba(6, 182, 212, 0.6);
    transition: width 0.2s ease;
  }
</style>