---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title?: string;
}

const { title = 'US MACRO - 投资数据研究平台' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="投资数据与内容平台 - 宏观经济数据、产业链图谱、投资大师文献" />
  </head>
  <body>
    <Sidebar />
    <main class="main">
      <slot />
    </main>
  </body>
</html>

<style>
  .main {
    margin-left: var(--sidebar-width);
    min-height: 100vh;
    padding: 24px 32px;
  }
</style>
