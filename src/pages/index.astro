---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { query } from '../lib/db';

const assets = await query(`
  SELECT a.id, a.symbol, a.name_zh, a.name_en,
         s.last_price, s.change_percent
  FROM assets a
  LEFT JOIN asset_snapshots s ON a.id = s.asset_id
  WHERE a.is_active = TRUE
  ORDER BY a.id
  LIMIT 8
`);

function formatChange(cp: any) {
  const num = cp == null ? null : Number(cp);
  if (num == null || isNaN(num)) return { text: '-', up: true };
  const text = (num >= 0 ? '+' : '') + num.toFixed(2) + '%';
  return { text, up: num >= 0 };
}

const now = new Date().toLocaleDateString('zh-CN');
---

<Layout title="今日判断 - US MACRO">
  <div class="page-header">
    <div class="date">{now} / 今日判断台</div>
    <div class="subtitle">核心资产数据 · 日线非实时 · 数据来源 Yahoo Finance / FRED</div>
  </div>

  <div class="asset-bar">
    {assets.map((asset: any) => {
      const ch = formatChange(asset.change_percent);
      return (
        <div class="asset-chip">
          <div class="asset-name">{asset.name_zh}</div>
          <div class="asset-value">{asset.last_price ?? '-'}</div>
          <div class={`asset-change ${ch.up ? 'up' : 'down'}`}>
            {ch.text}
          </div>
        </div>
      );
    })}
  </div>

  <div class="analysis-grid">
    <div class="analysis-card">
      <div class="card-header">
        <span class="tag evidence">证据</span>
        <h3>数据不足以支持新的今日判断</h3>
      </div>
      <p class="card-desc">当前核心数据状态不满足直接下结论的门槛。以下内容保留上一轮框架和观察清单，优先更新数据后再行动。</p>
      <div class="card-actions">
        <a href="/dashboard" class="btn btn-primary">市场仪表盘</a>
        <a href="/indicators/rates" class="btn btn-secondary">流动性传导链</a>
        <a href="/indicators/fed" class="btn btn-secondary">机构观点</a>
      </div>
    </div>

    <div class="side-panel">
      <div class="panel-section">
        <h4>今天只看这 3 件事</h4>
        <div class="mini-list">
          <div class="mini-item">
            <div class="mini-name">VIX</div>
            <div class="mini-meta">5日z-score -1.58 加速</div>
          </div>
          <div class="mini-item">
            <div class="mini-name">WTI原油</div>
            <div class="mini-meta">最新 $84.88/桶，日变动 -3.23%</div>
          </div>
          <div class="mini-item">
            <div class="mini-name">10Y国债收益率</div>
            <div class="mini-meta">最新 4.48%，日变动 +3.0bp</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="section-title">继续深入</div>
  <div class="quick-links">
    <a href="/indicators/GDP" class="quick-card">📊 GDP</a>
    <a href="/assets/equity" class="quick-card">📈 大类资产</a>
    <a href="/indicators/rates" class="quick-card">💹 利率</a>
    <a href="/indicators/liquidity" class="quick-card">💧 流动性</a>
    <a href="/industry/ai" class="quick-card">🤖 AI产业链</a>
    <a href="/industry/semiconductor" class="quick-card">🔬 半导体</a>
    <a href="/library" class="quick-card">📚 研究库</a>
    <a href="/reports" class="quick-card">📰 每日报告</a>
  </div>
</Layout>

<style>
  .page-header {
    margin-bottom: 20px;
  }

  .date {
    font-size: 20px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .subtitle {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 4px;
  }

  .asset-bar {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    padding-bottom: 8px;
    margin-bottom: 24px;
  }

  .asset-chip {
    flex-shrink: 0;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 12px 16px;
    min-width: 140px;
  }

  .asset-name {
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 4px;
  }

  .asset-value {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .asset-change {
    font-size: 12px;
    margin-top: 4px;
    font-weight: 500;
  }

  .asset-change.up { color: var(--accent-green); }
  .asset-change.down { color: var(--accent-red); }

  .analysis-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 20px;
    margin-bottom: 32px;
  }

  .analysis-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 20px;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .tag {
    font-size: 10px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tag.evidence {
    background: rgba(59, 130, 246, 0.15);
    color: var(--accent-blue);
  }

  .card-header h3 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .card-desc {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .card-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .btn {
    padding: 6px 14px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
    transition: all 0.15s ease;
  }

  .btn-primary {
    background: var(--accent-blue);
    color: white;
  }

  .btn-primary:hover {
    background: var(--accent-blue-hover);
    color: white;
  }

  .btn-secondary {
    background: var(--bg-hover);
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
  }

  .btn-secondary:hover {
    background: var(--border-color);
    color: var(--text-primary);
  }

  .side-panel {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .panel-section {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 16px;
  }

  .panel-section h4 {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 12px;
  }

  .mini-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .mini-item {
    padding: 8px;
    background: var(--bg-secondary);
    border-radius: 6px;
  }

  .mini-name {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-primary);
  }

  .mini-meta {
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 2px;
  }

  .section-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-color);
  }

  .quick-links {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 12px;
  }

  .quick-card {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 14px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    font-size: 13px;
    color: var(--text-secondary);
    transition: all 0.15s ease;
  }

  .quick-card:hover {
    background: var(--bg-hover);
    color: var(--text-primary);
    border-color: var(--accent-blue);
  }

  @media (max-width: 900px) {
    .analysis-grid {
      grid-template-columns: 1fr;
    }
    .asset-bar {
      flex-wrap: wrap;
    }
  }
</style>
