---
import Layout from '../layouts/Layout.astro';

const categories = [
  {
    title: '股东信',
    items: [
      { title: '巴菲特致股东信 2025', author: '沃伦·巴菲特', year: 2025 },
      { title: '巴菲特致股东信 2024', author: '沃伦·巴菲特', year: 2024 },
      { title: '芒格致股东信 2023', author: '查理·芒格', year: 2023 },
    ],
  },
  {
    title: '演讲与访谈',
    items: [
      { title: '2025年伯克希尔股东大会', author: '巴菲特 & 阿贝尔', year: 2025 },
      { title: 'Daily Journal 年会演讲', author: '查理·芒格', year: 2024 },
    ],
  },
  {
    title: '投资理念',
    items: [
      { title: '价值投资的核心原则', author: '本杰明·格雷厄姆', year: 1949 },
      { title: '护城河理论', author: '沃伦·巴菲特', year: 2007 },
    ],
  },
];
---

<Layout title="研究库 - US MACRO">
  <div class="page-header">
    <h1>研究库</h1>
    <p class="subtitle">投资大师文献 · 股东信 · 演讲 · 投资理念</p>
  </div>

  <div class="search-bar">
    <input type="text" placeholder="搜索文章、作者、年份..." class="search-input" />
  </div>

  {categories.map(cat => (
    <div class="category-section">
      <h2>{cat.title}</h2>
      <div class="article-list">
        {cat.items.map(item => (
          <div class="article-card">
            <div class="article-title">{item.title}</div>
            <div class="article-meta">
              <span class="author">{item.author}</span>
              <span class="year">{item.year}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}
</Layout>

<style>
  .page-header {
    margin-bottom: 20px;
  }

  .page-header h1 {
    font-size: 22px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .subtitle {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 4px;
  }

  .search-bar {
    margin-bottom: 24px;
  }

  .search-input {
    width: 100%;
    max-width: 400px;
    padding: 10px 14px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 13px;
    outline: none;
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .search-input:focus {
    border-color: var(--accent-blue);
  }

  .category-section {
    margin-bottom: 32px;
  }

  .category-section h2 {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-color);
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .article-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 14px 16px;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .article-card:hover {
    background: var(--bg-hover);
    border-color: var(--accent-blue);
  }

  .article-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
  }

  .article-meta {
    display: flex;
    gap: 12px;
    margin-top: 6px;
    font-size: 12px;
    color: var(--text-muted);
  }

  .author {
    color: var(--text-secondary);
  }

  .year {
    font-family: 'SF Mono', monospace;
  }
</style>
