---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { code: 'ai' } },
    { params: { code: 'semiconductor' } },
  ];
}

const { code } = Astro.params;

const industryNames: Record<string, string> = {
  ai: 'AI产业链',
  semiconductor: '半导体产业链',
};

const title = `${industryNames[code] || code} - US MACRO`;

const stats = {
  ai: { layers: 4, segments: 12, companies: 89, links: 156 },
  semiconductor: { layers: 4, segments: 15, companies: 120, links: 210 },
};

const s = stats[code as keyof typeof stats] || stats.ai;
---

<Layout title={title}>
  <div class="page-header">
    <h1>{industryNames[code] || code} 关系图谱</h1>
    <p class="subtitle">点击节点查看详情，从细分节点进入公司档案</p>
  </div>

  <div class="stats-bar">
    <div class="stat-box">
      <div class="stat-label">层级</div>
      <div class="stat-value">{s.layers}</div>
    </div>
    <div class="stat-box">
      <div class="stat-label">细分环节</div>
      <div class="stat-value">{s.segments}</div>
    </div>
    <div class="stat-box">
      <div class="stat-label">公司数</div>
      <div class="stat-value">{s.companies}</div>
    </div>
    <div class="stat-box">
      <div class="stat-label">关联关系</div>
      <div class="stat-value">{s.links}</div>
    </div>
  </div>

  <div class="graph-placeholder">
    <div class="placeholder-text">
      <div class="placeholder-icon">🕸️</div>
      <div>产业链网络图（Cytoscape.js 可视化区域）</div>
      <div class="placeholder-sub">节点：产业链环节 · 连线：供需/合作关系</div>
    </div>
  </div>

  <div class="node-list">
    <h2>核心节点</h2>
    <div class="node-grid">
      {['上游材料', '芯片设计', '晶圆制造', '封装测试', '终端应用'].map(node => (
        <div class="node-card">
          <div class="node-name">{node}</div>
          <div class="node-meta">点击查看关联公司与上下游</div>
        </div>
      ))}
    </div>
  </div>
</Layout>

<style>
  .page-header {
    margin-bottom: 20px;
  }

  .page-header h1 {
    font-size: 22px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .subtitle {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 4px;
  }

  .stats-bar {
    display: flex;
    gap: 16px;
    margin-bottom: 24px;
  }

  .stat-box {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 16px 24px;
    min-width: 100px;
  }

  .stat-label {
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-value {
    font-size: 24px;
    font-weight: 700;
    color: var(--text-primary);
    margin-top: 4px;
  }

  .graph-placeholder {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
  }

  .placeholder-text {
    text-align: center;
    color: var(--text-muted);
  }

  .placeholder-icon {
    font-size: 32px;
    margin-bottom: 8px;
  }

  .placeholder-sub {
    font-size: 11px;
    margin-top: 4px;
  }

  .node-list h2 {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 12px;
  }

  .node-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 12px;
  }

  .node-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 14px;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .node-card:hover {
    border-color: var(--accent-blue);
    background: var(--bg-hover);
  }

  .node-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-primary);
  }

  .node-meta {
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 4px;
  }
</style>
