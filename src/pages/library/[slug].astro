---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export const prerender = false;

const { slug } = Astro.params;
const articles = await getCollection('library');
const entry = articles.find(a => a.slug === slug);

if (!entry) {
  return new Response('Not Found', { status: 404 });
}

const { Content, headings } = await entry.render();
const { title, description, category, icon } = entry.data;

// 估算阅读时间（中文约 300 字/分钟）
const WORDS_PER_MIN = 300
const estimateReadingTime = (text: string): number => {
  const cn = (text.match(/[\u4e00-\u9fff]/g) || []).length
  const en = (text.match(/[a-zA-Z]+/g) || []).length
  return Math.max(1, Math.ceil((cn + en) / WORDS_PER_MIN))
}
const readingTime = estimateReadingTime(description || title)
const relatedArticles = articles.filter(a => a.slug !== slug && a.data.category === category).slice(0, 3)
---

<Layout title={`${title} - 研究库 - US MACRO`}>
  <div id="progress-bar"></div>

  <article class="article-layout">
    <aside class="toc-sidebar">
      <div class="toc-sticky">
        <div class="toc-title">目录</div>
        <nav class="toc-nav" id="toc-nav">
          {headings.filter(h => h.depth <= 3).map((h, i) => (
            <a href={`#${h.slug}`} class="toc-link" data-slug={h.slug} style={`padding-left: ${(h.depth - 2) * 12}px`}>
              {h.text}
            </a>
          ))}
        </nav>
      </div>
    </aside>

    <div class="article-content">
      <header class="article-header">
        <a href="/library" class="back-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          返回研究库
        </a>
        <div class="article-meta">
          <span class="article-category">{category}</span>
          <span class="article-reading-time">{readingTime} 分钟</span>
        </div>
        <h1 class="article-title">{title}</h1>
        {description && <p class="article-desc">{description}</p>}
      </header>

      <div class="markdown-body">
        <Content />
      </div>

      {relatedArticles.length > 0 && (
        <div class="related-section">
          <h3 class="related-title">相关文章</h3>
          <div class="related-grid">
            {relatedArticles.map(a => (
              <a href={`/library/${a.slug}`} class="related-card">
                <div class="related-card-title">{a.data.title}</div>
                <div class="related-card-desc">{a.data.description}</div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>

  <button id="scroll-top" class="scroll-top-btn" aria-label="回到顶部">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
  </button>
</Layout>

<script>
  (function() {
    // 阅读进度条
    const bar = document.getElementById('progress-bar')
    const updateProgress = () => {
      const scrollTop = window.scrollY
      const docHeight = document.documentElement.scrollHeight - window.innerHeight
      const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0
      bar.style.transform = `scaleX(${progress})`
    }
    window.addEventListener('scroll', updateProgress, { passive: true })
    updateProgress()

    // 目录高亮
    const tocLinks = document.querySelectorAll('.toc-link')
    const headings2 = document.querySelectorAll('.markdown-body h2, .markdown-body h3')
    const observer = new IntersectionObserver((entries) => {
      let activeId = ''
      entries.forEach(entry => {
        if (entry.isIntersecting) activeId = entry.target.id
      })
      if (activeId) {
        tocLinks.forEach(link => {
          link.classList.toggle('active', link.getAttribute('data-slug') === activeId)
        })
      }
    }, { rootMargin: '-80px 0px -60% 0px' })
    headings2.forEach(h => observer.observe(h))

    // 目录平滑滚动
    document.querySelectorAll('.toc-link').forEach(link => {
      link.addEventListener('click', e => {
        e.preventDefault()
        const target = document.getElementById(link.getAttribute('data-slug'))
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' })
        history.replaceState(null, '', link.getAttribute('href'))
      })
    })

    // 回到顶部
    const scrollBtn = document.getElementById('scroll-top')
    const toggleScrollBtn = () => {
      scrollBtn.classList.toggle('visible', window.scrollY > 400)
    }
    window.addEventListener('scroll', toggleScrollBtn, { passive: true })
    toggleScrollBtn()
    scrollBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' })
    })
  })()
</script>

<style>
  #progress-bar {
    position: fixed;
    top: var(--header-height);
    left: var(--sidebar-width);
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent-cyan), var(--accent-blue));
    transform-origin: left;
    transform: scaleX(0);
    z-index: 100;
    pointer-events: none;
  }

  .article-layout {
    display: flex;
    gap: 32px;
    max-width: 1100px;
  }

  .toc-sidebar { flex-shrink: 0; width: 200px; }
  .toc-sticky { position: sticky; top: calc(var(--header-height) + 24px); }

  .toc-title {
    font-size: 10px; font-weight: 600; font-family: var(--font-display);
    letter-spacing: 0.1em; color: var(--text-muted); text-transform: uppercase;
    margin-bottom: 12px;
  }

  .toc-nav { display: flex; flex-direction: column; gap: 4px; }

  .toc-link {
    font-size: 12px; color: var(--text-muted); line-height: 1.4;
    text-decoration: none; padding: 3px 0; transition: all var(--transition-fast);
    border-left: 2px solid transparent; padding-left: 12px;
  }

  .toc-link:hover { color: var(--accent-cyan); }
  .toc-link.active { color: var(--accent-cyan); border-left-color: var(--accent-cyan); }

  .article-content { flex: 1; min-width: 0; }

  .back-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; color: var(--text-muted); text-decoration: none;
    margin-bottom: 12px; transition: color var(--transition-fast);
  }
  .back-link:hover { color: var(--accent-cyan); }

  .article-header { margin-bottom: 32px; padding-bottom: 20px; border-bottom: 1px solid var(--border-light); }

  .article-meta {
    display: flex; align-items: center; gap: 8px; margin-bottom: 12px;
  }

  .article-category {
    font-size: 11px; padding: 2px 10px; border-radius: 4px;
    background: var(--accent-blue-dim); color: var(--accent-blue);
    font-weight: 500; letter-spacing: 0.04em;
  }

  .article-reading-time {
    font-size: 10px; color: var(--text-muted); font-family: var(--font-mono);
    letter-spacing: 0.04em; text-transform: uppercase;
  }

  .article-title {
    font-size: 26px; font-weight: 700; font-family: var(--font-display);
    letter-spacing: 0.01em; color: var(--text-primary); line-height: 1.3;
  }

  .article-desc { font-size: 13px; color: var(--text-secondary); margin-top: 8px; line-height: 1.6; }

  .markdown-body { color: var(--text-primary); font-size: 14px; line-height: 1.8; }

  .markdown-body h2 {
    font-size: 18px; font-weight: 600; margin: 32px 0 12px;
    padding-bottom: 8px; border-bottom: 1px solid var(--border-light);
    color: var(--text-primary); font-family: var(--font-display); letter-spacing: 0.02em;
    scroll-margin-top: calc(var(--header-height) + 20px);
  }

  .markdown-body h3 {
    font-size: 15px; font-weight: 600; margin: 24px 0 8px;
    color: var(--text-primary); scroll-margin-top: calc(var(--header-height) + 20px);
  }

  .markdown-body p { margin-bottom: 16px; color: var(--text-secondary); }
  .markdown-body ul, .markdown-body ol { margin: 8px 0; padding-left: 20px; }
  .markdown-body li { margin-bottom: 4px; color: var(--text-secondary); }

  .markdown-body code {
    font-size: 13px; padding: 2px 6px; border-radius: 4px;
    background: var(--accent-blue-dim); color: var(--accent-blue); font-family: var(--font-mono);
  }

  .markdown-body pre {
    background: #1a1b26; padding: 16px; border-radius: var(--radius-md);
    overflow-x: auto; margin: 16px 0;
  }

  .markdown-body pre code { background: none; padding: 0; color: #c9d1d9; }

  .markdown-body blockquote {
    border-left: 3px solid var(--accent-blue); padding: 12px 20px; margin: 16px 0;
    background: var(--accent-blue-dim); border-radius: 0 var(--radius-md) var(--radius-md) 0;
    color: var(--text-muted);
  }

  .markdown-body table {
    width: 100%; border-collapse: collapse; margin: 16px 0;
    border-radius: var(--radius-md); overflow: hidden;
  }

  .markdown-body th, .markdown-body td {
    padding: 10px 14px; border: 1px solid var(--border-light);
    text-align: left; font-size: 13px;
  }

  .markdown-body th {
    background: var(--bg-elevated); font-weight: 600;
    color: var(--text-primary); font-family: var(--font-display); letter-spacing: 0.03em;
  }

  .markdown-body td { color: var(--text-secondary); }
  .markdown-body tr:hover td { background: rgba(59, 130, 246, 0.05); }
  .markdown-body hr { border: none; border-top: 1px solid var(--border-color); margin: 24px 0; }
  .markdown-body strong { color: var(--text-primary); }
  .markdown-body a { color: var(--accent-cyan); }
  .markdown-body a:hover { color: var(--accent-cyan-hover); }
  .markdown-body img { border-radius: var(--radius-md); max-width: 100%; }

  .related-section { margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--border-light); }
  .related-title {
    font-size: 13px; font-weight: 600; font-family: var(--font-display);
    color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em;
    margin-bottom: 12px;
  }
  .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
  .related-card {
    padding: 14px; background: var(--bg-card); border-radius: var(--radius-md);
    text-decoration: none; transition: all var(--transition-base);
  }
  .related-card:hover { background: var(--bg-card-hover); }
  .related-card-title { font-size: 12px; font-weight: 600; color: var(--text-primary); transition: color var(--transition-fast); }
  .related-card:hover .related-card-title { color: var(--accent-cyan); }
  .related-card-desc { font-size: 11px; color: var(--text-muted); margin-top: 4px; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  .scroll-top-btn {
    position: fixed; bottom: 32px; right: 32px; z-index: 99;
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--bg-card); border: 1px solid var(--border-light);
    color: var(--text-muted); cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transform: translateY(12px); pointer-events: none;
    transition: all var(--transition-base);
    box-shadow: var(--shadow-md);
  }
  .scroll-top-btn.visible { opacity: 1; transform: translateY(0); pointer-events: auto; }
  .scroll-top-btn:hover { background: var(--accent-blue-dim); color: var(--accent-blue); border-color: var(--accent-blue); }
</style>
