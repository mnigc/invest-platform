---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import IndicatorChart from '../../../components/IndicatorChart';
import { query } from '../../../lib/db';

const { region, code } = Astro.params;

let indicator: any = null;
let latestValue: any = null;
let dbError: string | null = null;

try {
  const indicatorRows = await query(
    `SELECT * FROM indicators WHERE code = ? AND region = ? AND is_active = TRUE`,
    [code, region]
  );
  indicator = indicatorRows[0] as any;

  if (indicator) {
    const rows = await query(
      `SELECT period_date, value FROM indicator_data WHERE indicator_id = ? ORDER BY period_date DESC LIMIT 1`,
      [indicator.id]
    );
    latestValue = rows[0] as any;
    if (latestValue?.value != null) {
      const TRIL: Record<string, Record<string, number>> = {
        US: { GDP: 0.001, PCE: 0.001, RSXFS: 0.000001 },
        CN: { GDP: 0.0001, RETAIL: 0.0001 },
      };
      const factor = TRIL[region]?.[code];
      if (factor) {
        latestValue.value = Number(latestValue.value) * factor;
      }
    }
  }
} catch (e: any) {
  dbError = e.message || '数据库连接失败';
  console.error('[IndicatorPage]', dbError);
}

const title = indicator ? `${indicator.name_zh} - US MACRO` : '指标详情 - US MACRO';
const regionLabel = region === 'CN' ? '中国' : '美国';
---

<Layout title={title}>
  {dbError ? (
    <div class="page-header">
      <h1>数据加载失败</h1>
      <p class="subtitle" style="color: var(--red);">{dbError}</p>
      <p class="subtitle">请检查数据库连接或返回 <a href="/">市场仪表盘</a></p>
    </div>
  ) : indicator ? (
    <div class="page-animate">
      <div class="page-header">
        <div class="breadcrumb">
          <a href="/">首页</a>
          <span class="sep">/</span>
          <span>{regionLabel} 经济指标</span>
          <span class="sep">/</span>
          <span>{indicator.name_zh}</span>
        </div>
        <h1>{indicator.name_zh}</h1>
        <p class="subtitle">{indicator.description} · 数据来源 {indicator.source}</p>
      </div>

      <div class="hero-card">
        <div class="hero-glow"></div>
        <div class="hero-content">
          <div class="hero-label">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            最新值 ({indicator.unit})
          </div>
          <div class="hero-value">{latestValue?.value != null ? Number(latestValue.value).toFixed(3) : '-'}</div>
          <div class="hero-meta">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>{latestValue?.period_date ?? '暂无数据'}</span>
            <span class="hero-sep">|</span>
            <span>{indicator.frequency === 'daily' ? '日数据' : indicator.frequency === 'monthly' ? '月度数据' : '季度数据'}</span>
          </div>
        </div>
      </div>

      <IndicatorChart indicator={indicator} client:load />
    </div>
  ) : (
    <div class="page-header">
      <h1>指标未找到</h1>
      <p class="subtitle">请检查 URL 或返回 <a href="/">市场仪表盘</a></p>
    </div>
  )}
</Layout>

<style>
  .page-animate {
    animation: fadeIn 0.3s ease;
  }

  .page-header {
    margin-bottom: 20px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 6px;
  }

  .breadcrumb a {
    color: var(--text-muted);
    transition: color var(--transition-fast);
  }

  .breadcrumb a:hover {
    color: var(--accent-cyan);
  }

  .sep {
    color: var(--border-color);
    font-size: 10px;
  }

  .page-header h1 {
    font-size: 22px;
    font-weight: 700;
    font-family: var(--font-display);
    letter-spacing: 0.02em;
    color: var(--text-primary);
  }

  .subtitle {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 4px;
  }

  .hero-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid transparent;
    border-radius: var(--radius-xl);
    padding: 28px;
    margin-bottom: 24px;
    overflow: hidden;
    transition: all var(--transition-base);
  }

  .hero-card:hover {
    border-color: var(--accent-blue);
    box-shadow: var(--shadow-blue);
  }

  .hero-glow {
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .hero-label svg {
    color: var(--accent-blue);
  }

  .hero-value {
    font-size: 40px;
    font-weight: 700;
    font-family: var(--font-mono);
    color: var(--text-primary);
    letter-spacing: -0.03em;
    line-height: 1.1;
    text-shadow: 0 0 40px rgba(59, 130, 246, 0.1);
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--text-secondary);
    margin-top: 12px;
    font-family: var(--font-mono);
  }

  .hero-sep {
    color: var(--text-muted);
    opacity: 0.4;
  }
</style>