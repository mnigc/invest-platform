---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import IndicatorChart from '../../../components/IndicatorChart';
import { query } from '../../../lib/db';

const { region, code } = Astro.params;

let indicator: any = null;
let latestValue: any = null;
let stats: any = null;
let dbError: string | null = null;

try {
  const indicatorRows = await query(
    `SELECT * FROM indicators WHERE code = ? AND region = ? AND is_active = TRUE`,
    [code, region]
  );
  indicator = indicatorRows[0] as any;

  if (indicator) {
    const TRIL: Record<string, Record<string, number>> = {
      US: { GDP: 0.001, PCE: 0.001, RSXFS: 0.000001 },
      CN: { GDP: 0.0001, RETAIL: 0.0001 },
    };
    const factor = TRIL[region]?.[code];

    const rows = await query(
      `SELECT period_date, value FROM indicator_data WHERE indicator_id = ? ORDER BY period_date DESC`,
      [indicator.id]
    );

    if (rows && rows.length > 0) {
      const allData = rows.map((r: any) => ({
        period_date: r.period_date,
        value: factor ? Number(r.value) * factor : Number(r.value),
      }));

      latestValue = { period_date: allData[0].period_date, value: allData[0].value };

      const isQuarterly = indicator.frequency === 'quarterly' || indicator.frequency === 'daily';
      const yoyOffset = isQuarterly ? 4 : 12;

      const prevPeriod = allData[1];
      const yoyPeriod = allData[yoyOffset];

      const values = allData.map((d: any) => d.value);
      const high52 = Math.max(...values.slice(0, Math.min(52, values.length)));
      const low52 = Math.min(...values.slice(0, Math.min(52, values.length)));
      const highAll = Math.max(...values);
      const lowAll = Math.min(...values);
      const avg = values.reduce((a: number, b: number) => a + b, 0) / values.length;

      const qoq = prevPeriod ? ((latestValue.value - prevPeriod.value) / prevPeriod.value * 100) : null;
      const yoy = yoyPeriod ? ((latestValue.value - yoyPeriod.value) / yoyPeriod.value * 100) : null;

      const range = highAll - lowAll;
      const percentile = range > 0 ? ((latestValue.value - lowAll) / range * 100) : 50;

      stats = {
        latest: latestValue.value,
        latestDate: latestValue.period_date,
        qoq,
        yoy,
        qoqDate: prevPeriod?.period_date,
        yoyDate: yoyPeriod?.period_date,
        high52,
        low52,
        highAll,
        lowAll,
        avg,
        percentile,
        count: values.length,
      };
    }
  }
} catch (e: any) {
  dbError = e.message || '数据库连接失败';
  console.error('[IndicatorPage]', dbError);
}

const INDICATOR_INFO: Record<string, Record<string, {
  definition: string;
  up_means: string;
  down_means: string;
  future_up: string;
  future_down: string;
}>> = {
  US: {
    GDP: {
      definition: '国内生产总值（GDP）是衡量一国在特定时期内生产的所有最终商品和服务的市场价值总和，是最综合的经济总量指标。',
      up_means: 'GDP上涨通常意味着企业生产扩张、就业增加、居民收入上升，整体经济处于扩张或繁荣阶段。',
      down_means: 'GDP下降或增速放缓意味着经济活动收缩，企业减产、就业压力增大，可能预示经济衰退或进入调整期。',
      future_up: '若GDP持续上行，可能推动利率上升、股市估值抬升、企业盈利改善，但需警惕经济过热引发通胀。',
      future_down: '若GDP持续下行，央行可能降息刺激经济，财政政策可能加码基建与消费刺激，避险资产（黄金、国债）通常受益。',
    },
    CPI: {
      definition: '消费者价格指数（CPI）衡量一篮子代表性消费品和服务的价格变化，是反映通货膨胀水平的核心指标。',
      up_means: 'CPI上涨意味着生活成本上升、货币购买力下降，居民实际收入缩水，通常伴随日用消费品与服务价格普遍走高。',
      down_means: 'CPI下降或为负（通缩）意味着物价持续走弱，消费者可能推迟消费观望，企业定价能力下降，经济活力不足。',
      future_up: '若CPI持续上行，美联储可能加息以压制通胀，对债市、成长股和高估值板块形成压力；能源与必需消费品可能相对受益。',
      future_down: '若CPI持续走弱甚至通缩，央行可能降息或扩大量化宽松，利率下行环境对债券与成长风格资产有利，但需警惕经济长期停滞。',
    },
    PPI: {
      definition: '生产者价格指数（PPI）衡量工业企业出厂价格的变化，反映上游原材料和中间产品的价格压力，领先于CPI。',
      up_means: 'PPI上涨通常意味着原材料成本上升、工业品需求旺盛，产业链上游利润扩张，但也会逐步向下游传导推高CPI。',
      down_means: 'PPI下降意味着工业需求疲软、原材料价格走弱，企业库存承压，工业利润收窄，可能预示制造业进入下行周期。',
      future_up: '若PPI持续上行，说明通胀压力由上游向消费端传导，加息预期升温，周期股（能源、材料）短期受益但长期受压。',
      future_down: '若PPI持续下行，企业补库意愿减弱，制造业投资收缩，政策端可能通过降准降息、减税等方式刺激工业需求。',
    },
    PCE: {
      definition: '个人消费支出物价指数（PCE）是美联储官方首选的通胀衡量指标，覆盖居民全部消费支出的价格变化，权重可动态调整。',
      up_means: 'PCE上涨反映居民消费层面价格上升，尤其是服务消费涨价，直接影响美联储对通胀路径的判断及利率决策。',
      down_means: 'PCE下降意味着消费端通胀压力缓解，居民实际购买力改善，但持续走低可能反映消费需求不足。',
      future_up: '若核心PCE持续高于2%，美联储可能维持高利率甚至继续加息，美元走强，利率敏感板块承压。',
      future_down: '若PCE持续回落至2%附近，美联储具备降息空间，市场风险偏好通常上升，对成长股、房地产、债券市场形成利好。',
    },
    UMCSENT: {
      definition: '密歇根大学消费者信心指数（UMCSENT）通过对家庭的月度调查，评估消费者对当前经济状况和未来预期的信心水平。',
      up_means: '消费者信心上升意味着居民对就业和收入预期乐观，消费意愿增强，通常预示零售、服务消费后续走强。',
      down_means: '消费者信心下降意味着居民对经济前景担忧加剧，消费支出趋于谨慎，储蓄率可能上升，对零售和服务业形成压力。',
      future_up: '若信心持续改善，可选消费（汽车、旅游、零售）和服务业景气有望继续扩张，利好消费相关板块及整体GDP。',
      future_down: '若信心持续走弱，消费降级与延迟消费可能加剧，企业营收预期下修，央行可能转向宽松政策以稳定预期。',
    },
    RSXFS: {
      definition: '零售销售（Retail Sales）月度数据统计美国零售行业商品销售额的环比变化，直接反映居民消费支出的活跃度。',
      up_means: '零售销售上涨意味着消费需求旺盛，居民支出活跃，是经济韧性的直接信号，尤其对零售、快消、可选消费板块利好。',
      down_means: '零售销售下降意味着消费者支出收缩，商品需求走弱，通常伴随库存积压、零售企业打折清库存、利润承压。',
      future_up: '若零售持续走强，消费对GDP的拉动作用强化，但同时可能支撑通胀维持高位，延缓降息节奏。',
      future_down: '若零售持续走弱，经济增长的核心动力（消费）衰减，企业营收预期下调，可能倒逼政策端刺激消费与降息。',
    },
    FEDFUNDS: {
      definition: '联邦基金利率（Federal Funds Rate）是美国银行间同业拆借的基准利率，由美联储通过货币政策会议设定，是全球资本定价的锚。',
      up_means: '美联储加息意味着货币政策收紧，借贷成本上升，旨在抑制过热的经济和通胀；同时推高美元指数，压制风险资产估值。',
      down_means: '美联储降息意味着货币政策宽松，借贷成本下降，通常为应对经济下行或通缩风险，释放流动性以刺激投资与消费。',
      future_up: '若利率持续高位甚至上行，成长股、高负债企业和房地产承压，现金类、短期美债及银行净息差业务相对受益。',
      future_down: '若利率进入下行通道，债券价格上涨、成长风格股票估值抬升、房地产及耐用消费品需求改善，新兴市场资金回流。',
    },
  },
  CN: {
    GDP: {
      definition: '中国国内生产总值（GDP）衡量全国在特定时期内生产的所有最终商品和服务的市场价值总和，是观察中国经济总量与增速的核心指标。',
      up_means: 'GDP上涨通常对应工业生产扩张、投资与消费回暖、出口景气，反映经济政策见效和内生动力增强。',
      down_means: 'GDP增速回落意味着经济动能走弱，企业盈利承压，就业压力增大，可能出现地产下行、出口收缩或消费疲软。',
      future_up: '若GDP持续超预期，政策端可能减少刺激，利率稳中有升，上游周期与高端制造盈利弹性释放。',
      future_down: '若GDP持续下行，可能触发降准降息、基建加量、房地产政策松绑等稳增长组合拳，对债券与高股息资产形成支撑。',
    },
    CPI: {
      definition: '中国居民消费价格指数（CPI）统计居民家庭一般购买的消费商品和服务项目价格水平的变动，是反映通胀水平的核心指标。',
      up_means: 'CPI上涨意味着生活成本上升，尤其是食品与能源价格波动对居民影响较大，实际收入承压，低收入群体受影响更明显。',
      down_means: 'CPI持续低位或转负（通缩）意味着总需求不足，消费意愿低迷，企业商品销售困难，实际利率被动走高。',
      future_up: '若CPI持续上行，央行可能收紧货币或至少暂缓降息，必需消费品与农产品板块相对受益，债市承压。',
      future_down: '若CPI持续走弱甚至通缩，央行可能进一步降息、降准或通过财政发消费券等方式刺激总需求，利率敏感资产受益。',
    },
    PPI: {
      definition: '中国工业生产者出厂价格指数（PPI）反映全部工业产品出厂价格的变动趋势，是工业需求与利润的领先信号。',
      up_means: 'PPI上涨意味着上游原材料和工业品需求回暖、价格企稳回升，工业企业盈利改善，煤炭、钢铁、有色等行业利润扩张。',
      down_means: 'PPI下降意味着工业需求疲软，工业品价格持续下行，企业营收与利润双压，尤其对上游资源型行业影响显著。',
      future_up: '若PPI由负转正持续上行，周期风格（资源、化工、建材）有望迎来盈利修复，同时也可能传导至CPI推升通胀预期。',
      future_down: '若PPI持续下行，工业端去库存和亏损压力加大，政策可能通过加大基建投资、地产支持与产业基金等方式托底需求。',
    },
    RETAIL: {
      definition: '中国社会消费品零售总额统计商品零售和餐饮收入的月度变化，是观察居民实物消费与线下服务消费活力的直接指标。',
      up_means: '社零上涨意味着消费复苏，居民线下消费意愿增强，零售、餐饮、可选消费行业景气回升，是内需回暖的直接证据。',
      down_means: '社零下降或增速放缓意味着消费信心不足，居民倾向储蓄或减少非必需消费，对零售企业和服务业营收形成压力。',
      future_up: '若社零持续走强，消费对GDP拉动增强，可选消费（食品饮料、家电、服装、餐饮旅游）盈利修复确定性提升。',
      future_down: '若社零持续走弱，政策端可能通过发放消费券、下调消费税率、稳就业措施和房地产松绑等方式改善居民消费能力与预期。',
    },
    PMI: {
      definition: '中国制造业采购经理人指数（PMI）由国家统计局发布，通过对企业采购经理的月度调查汇总而成，50为荣枯分界线。',
      up_means: 'PMI高于50并上行意味着制造业扩张加速，新订单、生产、就业分项改善，工业企业景气回升，经济动能增强。',
      down_means: 'PMI低于50或持续下行意味着制造业收缩，需求不足、库存积压、企业补库意愿弱，经济面临下行压力。',
      future_up: '若PMI持续高于50，政策端可能保持中性，上游原材料、工业制造、出口链相关板块盈利修复确定性提升。',
      future_down: '若PMI跌破荣枯线并持续走弱，可能触发降准降息、基建加码、制造业设备更新补贴等稳增长政策出台。',
    },
  },
};

const indicatorInfo = INDICATOR_INFO[region]?.[code];
const title = indicator ? `${indicator.name_zh} - CN-US MACRO` : '指标详情 - CN-US MACRO';
const regionLabel = region === 'CN' ? '中国' : '美国';
---

<Layout title={title}>
  {dbError ? (
    <div class="page-header">
      <h1>数据加载失败</h1>
      <p class="subtitle" style="color: var(--red);">{dbError}</p>
      <p class="subtitle">请检查数据库连接或返回 <a href="/">市场仪表盘</a></p>
    </div>
  ) : indicator ? (
    <div class="page-animate">
      <div class="page-header">
        <div class="breadcrumb">
          <a href="/">首页</a>
          <span class="sep">/</span>
          <span>{regionLabel} 经济指标</span>
          <span class="sep">/</span>
          <span>{indicator.name_zh}</span>
        </div>
        <h1>{indicator.name_zh}</h1>
        <p class="subtitle">{indicator.description} · 数据来源 {indicator.source}</p>
      </div>

      <div class="hero-row">
        <div class="hero-card">
          <div class="hero-glow"></div>
          <div class="hero-content">
            <div class="hero-header">
              <div class="hero-left">
                <div class="hero-label">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                  最新值 ({indicator.unit})
                </div>
                <div class="hero-value">{latestValue?.value != null ? Number(latestValue.value).toFixed(3) : '-'}</div>
                <div class="hero-meta">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  <span>{latestValue?.period_date ?? '暂无数据'}</span>
                  <span class="hero-sep">|</span>
                  <span>{indicator.frequency === 'daily' ? '日数据' : indicator.frequency === 'monthly' ? '月度数据' : '季度数据'}</span>
                </div>
              </div>
              {stats && (
                <div class="hero-changes">
                  <div class:list={['change-item', stats.yoy != null && stats.yoy >= 0 ? 'positive' : 'negative']}>
                    <div class="change-label">同比</div>
                    <div class="change-value">{stats.yoy != null ? `${stats.yoy >= 0 ? '↑' : '↓'} ${Math.abs(stats.yoy).toFixed(2)}%` : '-'}</div>
                    <div class="change-date">vs {stats.yoyDate ?? '-'}</div>
                  </div>
                  <div class:list={['change-item', stats.qoq != null && stats.qoq >= 0 ? 'positive' : 'negative']}>
                    <div class="change-label">环比</div>
                    <div class="change-value">{stats.qoq != null ? `${stats.qoq >= 0 ? '↑' : '↓'} ${Math.abs(stats.qoq).toFixed(2)}%` : '-'}</div>
                    <div class="change-date">vs {stats.qoqDate ?? '-'}</div>
                  </div>
                </div>
              )}
            </div>

            {stats && (
              <div class="hero-stats">
                <div class="stat-row">
                  <div class="stat-cell">
                    <div class="stat-label">52周最高</div>
                    <div class="stat-value high">{Number(stats.high52).toFixed(3)}</div>
                  </div>
                  <div class="stat-cell">
                    <div class="stat-label">52周最低</div>
                    <div class="stat-value low">{Number(stats.low52).toFixed(3)}</div>
                  </div>
                  <div class="stat-cell">
                    <div class="stat-label">历史均值</div>
                    <div class="stat-value">{Number(stats.avg).toFixed(3)}</div>
                  </div>
                </div>

                <div class="range-container">
                  <div class="range-labels">
                    <span class="range-label">历史最低 {Number(stats.lowAll).toFixed(3)}</span>
                    <span class="range-label">历史最高 {Number(stats.highAll).toFixed(3)}</span>
                  </div>
                  <div class="range-bar">
                    <div class="range-fill" style={`width:${Math.min(100, Math.max(0, Number(stats.percentile)))}%`}></div>
                    <div class="range-marker" style={`left:${Math.min(100, Math.max(0, Number(stats.percentile)))}%`}></div>
                  </div>
                  <div class="range-percentile">
                    当前值处于历史 <strong>{Number(stats.percentile).toFixed(1)}%</strong> 分位 · 共 {stats.count} 个数据点
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>

        {indicatorInfo && (
          <div class="info-card">
            <div class="info-label">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
              指标说明
            </div>
            <div class="info-grid">
              <div class="info-col">
                <div class="info-item">
                  <div class="info-item-title">名词解释</div>
                  <div class="info-item-text">{indicatorInfo.definition}</div>
                </div>
                <div class="info-item">
                  <div class="info-item-title up">上涨代表</div>
                  <div class="info-item-text">{indicatorInfo.up_means}</div>
                </div>
                <div class="info-item">
                  <div class="info-item-title down">下跌代表</div>
                  <div class="info-item-text">{indicatorInfo.down_means}</div>
                </div>
              </div>
              <div class="info-col">
                <div class="info-item">
                  <div class="info-item-title up">未来上行影响</div>
                  <div class="info-item-text">{indicatorInfo.future_up}</div>
                </div>
                <div class="info-item">
                  <div class="info-item-title down">未来下行影响</div>
                  <div class="info-item-text">{indicatorInfo.future_down}</div>
                </div>
              </div>
            </div>
          </div>
        )}
      </div>

      <IndicatorChart indicator={indicator} client:only="react" />
    </div>
  ) : (
    <div class="page-header">
      <h1>指标未找到</h1>
