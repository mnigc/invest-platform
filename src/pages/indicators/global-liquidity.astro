---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import GlobalLiquidityDashboard from '../../components/GlobalLiquidityDashboard';
---

<Layout title="全球流动性 - CN-US MACRO">
  <div class="page-animate">
    <div class="page-header">
      <div class="breadcrumb">
        <a href="/">首页</a>
        <span class="sep">/</span>
        <span>跨市场分析</span>
        <span class="sep">/</span>
        <span>全球流动性</span>
      </div>
      <h1>全球流动性监测</h1>
      <p class="subtitle">美联储资产负债表 · RRP · TGA · 主要央行对比 · SOFR</p>
    </div>

    <div class="guide">
      <div class="guide-title">📖 指标解读</div>
      <div class="guide-body">
        <p><strong>全球流动性</strong>就是全世界"钱的总量"。钱越多，资产价格（股票、房子、黄金）越容易涨；钱越少，市场容易跌。这里跟踪几个最关键的指标：</p>
        <ul>
          <li><strong>美联储总资产</strong> — 美国印了多少钱。2008 年金融危机和 2020 年疫情后大幅扩张，2022 年开始缩表（逐步回收）。总资产涨 → 市场有钱 → 利好资产。</li>
          <li><strong>RRP（隔夜逆回购）</strong> — 银行/基金"暂时借给美联储"的钱。RRP 越高说明市场里闲钱多但不敢投，是流动性淤积的信号。RRP 从 2023 年的 2.5 万亿降到接近 0，说明流动性正在从"淤积"变为"紧张"。</li>
          <li><strong>TGA（财政部账户）</strong> — 美国政府存在美联储的活期存款。TGA 增加 = 政府收税/发债把钱从市场中抽走（紧缩）；TGA 减少 = 政府花钱把钱注入市场（宽松）。</li>
          <li><strong>SOFR（担保隔夜融资利率）</strong> — 银行之间借钱的利率。SOFR 越高说明市场缺钱，越低说明流动性充裕。类似"市场缺钱程度的体温计"。</li>
          <li><strong>主要央行资产负债表对比</strong> — 把美联储、欧央行、日央行的总资产放在一起比较（以 100 为基准），看哪家在放水、哪家在紧缩。</li>
        </ul>
        <p class="guide-tldr"><strong>一句话：</strong>总资产↑ RRP↓ TGA↓ = 市场钱多，利好风险资产；反过来总资产↓ RRP↑ TGA↑ = 钱少，要小心。</p>
      </div>
    </div>

    <GlobalLiquidityDashboard client:load />
  </div>
</Layout>

<style>
  .page-animate {
    animation: fadeIn 0.3s ease;
  }
  .page-header {
    margin-bottom: 20px;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 6px;
  }
  .breadcrumb a { color: var(--text-muted); transition: color var(--transition-fast); }
  .breadcrumb a:hover { color: var(--accent-cyan); }
  .sep { color: var(--border-color); font-size: 10px; }
  .page-header h1 {
    font-size: 22px; font-weight: 700; font-family: var(--font-display);
    letter-spacing: 0.02em; color: var(--text-primary); margin: 0;
  }
  .subtitle { font-size: 12px; color: var(--text-muted); margin-top: 4px; }
  .guide {
    margin-bottom: 20px;
    padding: 14px 18px;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-secondary);
  }
  .guide-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
  }
  .guide-body p { margin: 6px 0; }
  .guide-body ul { margin: 6px 0; padding-left: 18px; }
  .guide-body li { margin: 4px 0; }
  .guide-tldr {
    margin-top: 8px;
    padding: 8px 12px;
    background: var(--accent-blue-dim);
    border-radius: var(--radius-md);
    font-size: 12px;
  }
</style>
