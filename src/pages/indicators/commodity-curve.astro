---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import CommodityCurveDashboard from '../../components/CommodityCurveDashboard';
---

<Layout title="商品期限结构 - CN-US MACRO">
  <div class="page-animate">
    <div class="page-header">
      <div class="breadcrumb">
        <a href="/">首页</a>
        <span class="sep">/</span>
        <span>大宗商品</span>
        <span class="sep">/</span>
        <span>商品期限结构</span>
      </div>
      <h1>商品期限结构</h1>
      <p class="subtitle">Commodity Curve Monitor · 远月升水 / 贴水 · 跨商品曲线对比</p>
    </div>

    <CommodityCurveDashboard client:load />
  </div>
</Layout>

<style>
  .page-animate {
    animation: fadeIn 0.3s ease;
  }
  .page-header {
    margin-bottom: 20px;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 6px;
  }
  .breadcrumb a { color: var(--text-muted); transition: color var(--transition-fast); }
  .breadcrumb a:hover { color: var(--accent-cyan); }
  .sep { color: var(--border-color); font-size: 10px; }
  .page-header h1 {
    font-size: 22px; font-weight: 700; font-family: var(--font-display);
    letter-spacing: 0.02em; color: var(--text-primary); margin: 0;
  }
  .subtitle { font-size: 12px; color: var(--text-muted); margin-top: 4px; }
</style>
