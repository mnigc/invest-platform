---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { ForexDashboard } from '../../components/ForexDashboard';
---

<Layout title="汇率总览 - CN-US MACRO">
  <div class="page-animate">
    <div class="page-header">
      <div class="breadcrumb">
        <a href="/">首页</a>
        <span class="sep">/</span>
        <a href="/indicators/cn-us-spread">跨市场分析</a>
        <span class="sep">/</span>
        <span>汇率总览</span>
      </div>
      <h1>汇率总览</h1>
      <p class="subtitle">美元指数 · 主要货币对 · 成分权重拆解 · 交叉资产联动</p>
    </div>

    <ForexDashboard client:load />
  </div>
</Layout>

<style>
  .page-animate {
    animation: fadeIn 0.3s ease;
  }
  .page-header {
    margin-bottom: 20px;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 6px;
  }
  .breadcrumb a { color: var(--text-muted); transition: color var(--transition-fast); }
  .breadcrumb a:hover { color: var(--accent-cyan); }
  .sep { color: var(--border-color); font-size: 10px; }
  .page-header h1 {
    font-size: 22px; font-weight: 700; font-family: var(--font-display);
    letter-spacing: 0.02em; color: var(--text-primary); margin: 0;
  }
  .subtitle { font-size: 12px; color: var(--text-muted); margin-top: 4px; }
</style>