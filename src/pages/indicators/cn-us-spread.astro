---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import CnUsSpreadDashboard from '../../components/CnUsSpreadDashboard';
---

<Layout title="中美 10 年期国债利差 - CN-US MACRO">
  <div class="page-animate">
    <div class="page-header">
      <div class="breadcrumb">
        <a href="/">首页</a>
        <span class="sep">/</span>
        <span>跨市场分析</span>
        <span class="sep">/</span>
        <span>中美利差</span>
      </div>
      <h1>中美 10 年期国债利差</h1>
      <p class="subtitle">中国 10Y − 美国 10Y · 历史分位 · 警戒线 · 倒挂统计</p>
    </div>

    <CnUsSpreadDashboard client:load />
  </div>
</Layout>

<style>
  .page-animate {
    animation: fadeIn 0.3s ease;
  }
  .page-header {
    margin-bottom: 20px;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 6px;
  }
  .breadcrumb a { color: var(--text-muted); transition: color var(--transition-fast); }
  .breadcrumb a:hover { color: var(--accent-cyan); }
  .sep { color: var(--border-color); font-size: 10px; }
  .page-header h1 {
    font-size: 22px; font-weight: 700; font-family: var(--font-display);
    letter-spacing: 0.02em; color: var(--text-primary); margin: 0;
  }
  .subtitle { font-size: 12px; color: var(--text-muted); margin-top: 4px; }
</style>
