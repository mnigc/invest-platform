---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import PmiDashboard from '../../../components/PmiDashboard';
---

<Layout title="PMI 采购经理人指数 - CN-US MACRO">
  <div class="page-animate">
    <div class="page-header">
      <div class="breadcrumb">
        <a href="/">首页</a>
        <span class="sep">/</span>
        <a href="/indicators/US/GDP">美国经济指标</a>
        <span class="sep">/</span>
        <span>PMI 采购经理人指数</span>
      </div>
      <h1>PMI 采购经理人指数</h1>
      <p class="subtitle">美国 ISM 制造业 · 中国财新制造业 · 中国非制造业 — 50 为荣枯分界线</p>
    </div>

    <PmiDashboard client:load />
  </div>
</Layout>

<style>
  .page-animate {
    animation: fadeIn 0.3s ease;
  }
  .page-header {
    margin-bottom: 20px;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 6px;
  }
  .breadcrumb a { color: var(--text-muted); transition: color var(--transition-fast); }
  .breadcrumb a:hover { color: var(--accent-cyan); }
  .sep { color: var(--border-color); font-size: 10px; }
  .page-header h1 {
    font-size: 22px; font-weight: 700; font-family: var(--font-display);
    letter-spacing: 0.02em; color: var(--text-primary); margin: 0;
  }
  .subtitle { font-size: 12px; color: var(--text-muted); margin-top: 4px; }
  .error-box {
    padding: 14px 18px; border-radius: var(--radius-xl);
    background: var(--red-bg); color: var(--red); font-size: 13px;
    border: 1px solid var(--red-bg);
  }
</style>
