{
  "name": "invest-platform",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "astro dev",
    "dev:full": "concurrently -n api,web -c yellow,cyan \"npm run api:dev\" \"astro dev\"",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "api:dev": "npm run dev -w @invest/api",
    "api:build": "npm run build -w @invest/api"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^3.1.9",
    "@astrojs/node": "^8.3.4",
    "@astrojs/react": "^3.4.0",
    "@tanstack/react-query": "^5.101.0",
    "astro": "^4.9.0",
    "echarts": "^5.5.0",
    "mysql2": "^3.22.5",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^10.0.3",
    "typescript": "^5.9.3"
  }
}
